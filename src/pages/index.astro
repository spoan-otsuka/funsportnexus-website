---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="fun sport nexus" description="明るく、楽しく、人と人をつなぐ。fun sport nexus 公式サイト">

  <main style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, var(--fsn-navy-deep), var(--fsn-navy)); color: white; padding: 40px 20px;">
    <div style="text-align: center; max-width: 720px;">
      <p style="font-size: 0.78rem; font-weight: 700; letter-spacing: 0.3em; color: var(--fsn-orange); margin: 0 0 16px;">FUN SPORT NEXUS</p>
      <h1 style="font-size: clamp(2rem, 5vw, 3.4rem); font-weight: 800; color: white; margin: 0 0 28px; line-height: 1.4;">
        明るく、楽しく、<br>人と人をつなぐ。
      </h1>
      <p style="font-size: 1.05rem; line-height: 1.9; color: rgba(255,255,255,0.92); margin: 0 0 32px;">
        公式サイトを、ただいま準備中です。<br>
        2026年9月の公開を、目指しております。
      </p>
      <p style="font-size: 0.9rem; color: rgba(255,255,255,0.7); margin: 32px 0 0;">
        公益財団法人 スポーツ安全協会<br>
        <a href="mailto:funsportnexus@spoan.or.jp" style="color: var(--fsn-orange); border-bottom: 1px dashed rgba(249,115,22,0.4); padding-bottom: 2px;">funsportnexus@spoan.or.jp</a>
      </p>
    </div>
  </main>

</BaseLayout>
