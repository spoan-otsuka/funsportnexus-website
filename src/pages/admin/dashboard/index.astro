---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export const prerender = false;

const env = Astro.locals?.runtime?.env ?? {};

let errorMsg = null;
let kpi = { entry: 0, attendee: 0, slot: 0, checkin: 0, panJoin: 0, panExtras: 0, day1Only: 0, day2Only: 0, both: 0, ckDay1: 0, ckDay2: 0, ckTest: 0 };
let slotRows = [];
let gradeRows = [];
let dailyRows = [];
let recentEntries = [];
let recentCheckins = [];
let extrasAttrs = {};

const safeGet = async (sql, params = []) => {
  try {
    return await env.DB.prepare(sql).bind(...params).first();
  } catch (e) { errorMsg = e.message; return null; }
};
const safeAll = async (sql, params = []) => {
  try {
    return (await env.DB.prepare(sql).bind(...params).all())?.results ?? [];
  } catch (e) { errorMsg = e.message; return []; }
};

if (env.DB) {
  const r1 = await safeGet(`SELECT COUNT(*) AS c FROM entries WHERE status='confirmed'`);
  kpi.entry = r1?.c ?? 0;
  const r2 = await safeGet(`SELECT COUNT(*) AS c FROM entry_attendees ea INNER JOIN entries e ON ea.entry_id=e.id WHERE e.status='confirmed'`);
  kpi.attendee = r2?.c ?? 0;
  const r3 = await safeGet(`SELECT COUNT(*) AS c FROM entry_slots es INNER JOIN entries e ON es.entry_id=e.id WHERE e.status='confirmed'`);
  kpi.slot = r3?.c ?? 0;
  const r4 = await safeGet(`SELECT COUNT(*) AS c FROM entries WHERE status='confirmed' AND checked_in_at IS NOT NULL`);
  kpi.checkin = r4?.c ?? 0;
  // entry_checkins ベース（日別の実チェックイン数）
  const ckDayRows = await safeAll(`SELECT day AS d, COUNT(*) AS c FROM entry_checkins GROUP BY day`);
  for (const r of ckDayRows) {
    if (r.d === 'Day1') kpi.ckDay1 = r.c;
    else if (r.d === 'Day2') kpi.ckDay2 = r.c;
    else kpi.ckTest += r.c;
  }
  const r5 = await safeGet(`SELECT COUNT(*) AS c FROM entry_attendees ea INNER JOIN entries e ON ea.entry_id=e.id WHERE e.status='confirmed' AND ea.panshoku_join=1`);
  kpi.panJoin = r5?.c ?? 0;
  const r6 = await safeGet(`SELECT COUNT(*) AS c FROM entries WHERE status='confirmed' AND panshoku_extras IS NOT NULL`);
  kpi.panExtras = r6?.c ?? 0;

  // Day別参加（参加者単位で重複なくカウント）
  const dayCounts = await safeAll(`
    SELECT ea.id AS aid, GROUP_CONCAT(DISTINCT s.day) AS days
    FROM entry_attendees ea
    INNER JOIN entries e ON ea.entry_id=e.id AND e.status='confirmed'
    LEFT JOIN entry_slots es ON es.attendee_id = ea.id
    LEFT JOIN slots s ON es.slot_id = s.id
    GROUP BY ea.id
  `);
  for (const r of dayCounts) {
    const days = (r.days || '').split(',').filter(Boolean);
    const has1 = days.includes('Day1');
    const has2 = days.includes('Day2');
    if (has1 && has2) kpi.both++;
    else if (has1) kpi.day1Only++;
    else if (has2) kpi.day2Only++;
  }

  // プログラム別充填
  slotRows = await safeAll(`
    SELECT s.id, s.program_name, s.day, s.time_start, s.time_end, s.venue, s.capacity,
      COUNT(es.id) AS reserved
    FROM slots s
    LEFT JOIN entry_slots es ON s.id = es.slot_id
    LEFT JOIN entries e ON es.entry_id = e.id AND e.status='confirmed'
    WHERE s.is_active=1
    GROUP BY s.id
    ORDER BY s.day, s.time_start, s.id
  `);

  // 学年別
  gradeRows = await safeAll(`
    SELECT COALESCE(NULLIF(ea.grade,''),'未入力') AS grade, COUNT(*) AS c
    FROM entry_attendees ea
    INNER JOIN entries e ON ea.entry_id=e.id AND e.status='confirmed'
    GROUP BY grade
    ORDER BY c DESC
  `);

  // 日別申込推移
  dailyRows = await safeAll(`
    SELECT DATE(created_at) AS d, COUNT(*) AS c
    FROM entries WHERE status='confirmed'
    GROUP BY DATE(created_at)
    ORDER BY d
  `);

  // 最近の申込
  recentEntries = await safeAll(`
    SELECT id, applicant_name, email, attendees, created_at, checked_in_at
    FROM entries WHERE status='confirmed'
    ORDER BY id DESC LIMIT 10
  `);

  // 最近のチェックイン
  recentCheckins = await safeAll(`
    SELECT id, applicant_name, attendees, checked_in_at
    FROM entries WHERE status='confirmed' AND checked_in_at IS NOT NULL
    ORDER BY checked_in_at DESC LIMIT 10
  `);

  // ぱん食い同行者の属性集計
  const extrasJsonRows = await safeAll(`
    SELECT panshoku_extras FROM entries WHERE status='confirmed' AND panshoku_extras IS NOT NULL
  `);
  for (const r of extrasJsonRows) {
    try {
      const arr = JSON.parse(r.panshoku_extras || '[]');
      for (const x of arr) {
        const attr = x.attr || '未設定';
        extrasAttrs[attr] = (extrasAttrs[attr] || 0) + 1;
      }
    } catch {}
  }
}

const pct = (n, d) => d > 0 ? Math.round((n / d) * 100) : 0;
const day1Slots = slotRows.filter(s => s.day === 'Day1');
const day2Slots = slotRows.filter(s => s.day === 'Day2');
const checkinPct = pct(kpi.checkin, kpi.entry);
const panPct = pct(kpi.panJoin, kpi.attendee);

const dailyMax = dailyRows.length ? Math.max(...dailyRows.map(r => r.c)) : 0;
const gradeMax = gradeRows.length ? Math.max(...gradeRows.map(r => r.c)) : 0;
const extrasMax = Object.values(extrasAttrs).length ? Math.max(...Object.values(extrasAttrs)) : 0;
const extrasTotal = Object.values(extrasAttrs).reduce((s, v) => s + v, 0);
---
<BaseLayout
  title="ダッシュボード ｜ fun sport nexus 管理"
  description="運営用 申込状況ダッシュボード"
  noindex={true}
  hideHeader={true}
  hideFooter={true}
>

  <div class="dash-wrap">
    <header class="dash-head">
      <div>
        <a href="/admin/" class="dash-back">← 管理TOP</a>
        <h1>ダッシュボード ／ fun sport nexus 2026.12</h1>
      </div>
      <button onclick="location.reload()" class="dash-btn">
        <i class="fa-solid fa-rotate"></i> 更新
      </button>
    </header>

    {errorMsg && <div class="dash-error">エラー: {errorMsg}</div>}

    <!-- KPIカード -->
    <section class="dash-section">
      <h2 class="dash-section__title"><i class="fa-solid fa-chart-line"></i> 全体指標</h2>
      <div class="dash-kpi">
        <div class="kpi">
          <p class="kpi__label">申込件数</p>
          <p class="kpi__num">{kpi.entry}</p>
          <p class="kpi__unit">件</p>
        </div>
        <div class="kpi">
          <p class="kpi__label">参加者総数</p>
          <p class="kpi__num">{kpi.attendee}</p>
          <p class="kpi__unit">名</p>
        </div>
        <div class="kpi">
          <p class="kpi__label">のべ予約数</p>
          <p class="kpi__num">{kpi.slot}</p>
          <p class="kpi__unit">枠</p>
        </div>
        <div class="kpi kpi--cyan">
          <p class="kpi__label">チェックイン</p>
          <p class="kpi__num">{kpi.checkin}<span class="kpi__sub">/{kpi.entry}</span></p>
          <p class="kpi__unit">{checkinPct}%</p>
        </div>
        <div class="kpi kpi--orange">
          <p class="kpi__label">ぱん食い 参加意思</p>
          <p class="kpi__num">{kpi.panJoin}<span class="kpi__sub">/{kpi.attendee}</span></p>
          <p class="kpi__unit">{panPct}%</p>
        </div>
        <div class="kpi kpi--orange">
          <p class="kpi__label">当日同行者 登録</p>
          <p class="kpi__num">{extrasTotal}</p>
          <p class="kpi__unit">名 ({kpi.panExtras}件)</p>
        </div>
      </div>
    </section>

    <!-- Day別参加 -->
    <section class="dash-section">
      <h2 class="dash-section__title"><i class="fa-regular fa-calendar"></i> 参加日内訳（参加者単位）</h2>
      <div class="dash-day">
        <div class="day-tile day-tile--navy">
          <p class="day-tile__day">DAY 1 のみ</p>
          <p class="day-tile__num">{kpi.day1Only}<span class="day-tile__unit">名</span></p>
        </div>
        <div class="day-tile day-tile--orange">
          <p class="day-tile__day">DAY 2 のみ</p>
          <p class="day-tile__num">{kpi.day2Only}<span class="day-tile__unit">名</span></p>
        </div>
        <div class="day-tile day-tile--both">
          <p class="day-tile__day">両日参加</p>
          <p class="day-tile__num">{kpi.both}<span class="day-tile__unit">名</span></p>
        </div>
      </div>
    </section>

    <!-- Day別チェックイン -->
    <section class="dash-section">
      <h2 class="dash-section__title"><i class="fa-solid fa-circle-check"></i> 当日チェックイン（申込単位）</h2>
      <div class="dash-day">
        <div class="day-tile day-tile--navy">
          <p class="day-tile__day">DAY 1 (12/19) チェックイン</p>
          <p class="day-tile__num">{kpi.ckDay1}<span class="day-tile__unit">件</span></p>
        </div>
        <div class="day-tile day-tile--orange">
          <p class="day-tile__day">DAY 2 (12/20) チェックイン</p>
          <p class="day-tile__num">{kpi.ckDay2}<span class="day-tile__unit">件</span></p>
        </div>
        <div class="day-tile" style="background:var(--fsn-gray-700);">
          <p class="day-tile__day">テストチェックイン</p>
          <p class="day-tile__num">{kpi.ckTest}<span class="day-tile__unit">件</span></p>
        </div>
      </div>
    </section>

    <!-- プログラム別充填率 -->
    <section class="dash-section">
      <h2 class="dash-section__title"><i class="fa-solid fa-clipboard-list"></i> プログラム別 充填率</h2>
      <div class="dash-cols">
        <div class="dash-col">
          <h3 class="dash-col__title"><span class="day-pill day-pill--navy">DAY 1</span> 12/19（土）</h3>
          <table class="dash-table">
            <thead><tr><th>プログラム</th><th>時間</th><th>会場</th><th>予約／定員</th><th>充填率</th></tr></thead>
            <tbody>
              {day1Slots.map(s => {
                const p = pct(s.reserved, s.capacity);
                return (
                  <tr>
                    <td><a href={`/admin/programs/${s.id}/`}>{s.program_name}</a></td>
                    <td><small>{s.time_start}〜{s.time_end}</small></td>
                    <td><small>{s.venue}</small></td>
                    <td><strong>{s.reserved}</strong> / {s.capacity}</td>
                    <td>
                      <div class="bar"><div class="bar__fill" style={`width:${p}%;background:${p>=80?'#dc2626':p>=50?'var(--fsn-orange)':'var(--fsn-navy)'};`}></div></div>
                      <span class="bar__pct">{p}%</span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <div class="dash-col">
          <h3 class="dash-col__title"><span class="day-pill day-pill--orange">DAY 2</span> 12/20（日）</h3>
          <table class="dash-table">
            <thead><tr><th>プログラム</th><th>時間</th><th>会場</th><th>予約／定員</th><th>充填率</th></tr></thead>
            <tbody>
              {day2Slots.map(s => {
                const p = pct(s.reserved, s.capacity);
                return (
                  <tr>
                    <td><a href={`/admin/programs/${s.id}/`}>{s.program_name}</a></td>
                    <td><small>{s.time_start}〜{s.time_end}</small></td>
                    <td><small>{s.venue}</small></td>
                    <td><strong>{s.reserved}</strong> / {s.capacity}</td>
                    <td>
                      <div class="bar"><div class="bar__fill" style={`width:${p}%;background:${p>=80?'#dc2626':p>=50?'var(--fsn-orange)':'var(--fsn-navy)'};`}></div></div>
                      <span class="bar__pct">{p}%</span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- 学年別 + 同行者属性 + 日別申込 -->
    <section class="dash-section">
      <div class="dash-cols">
        <div class="dash-col">
          <h3 class="dash-col__title"><i class="fa-solid fa-graduation-cap"></i> 参加者の学年内訳</h3>
          <ul class="dash-list">
            {gradeRows.map(r => (
              <li class="dash-list__item">
                <span class="dash-list__label">{r.grade}</span>
                <div class="bar"><div class="bar__fill" style={`width:${pct(r.c, gradeMax)}%;background:var(--fsn-navy);`}></div></div>
                <span class="dash-list__num">{r.c}名</span>
              </li>
            ))}
            {gradeRows.length === 0 && <li class="dash-list__empty">データなし</li>}
          </ul>
        </div>

        <div class="dash-col">
          <h3 class="dash-col__title"><i class="fa-solid fa-bread-slice"></i> ぱん食い 当日同行者の属性</h3>
          <ul class="dash-list">
            {Object.entries(extrasAttrs).sort((a,b)=>b[1]-a[1]).map(([attr, c]) => (
              <li class="dash-list__item">
                <span class="dash-list__label">{attr}</span>
                <div class="bar"><div class="bar__fill" style={`width:${pct(c, extrasMax)}%;background:var(--fsn-orange);`}></div></div>
                <span class="dash-list__num">{c}名</span>
              </li>
            ))}
            {Object.keys(extrasAttrs).length === 0 && <li class="dash-list__empty">同行者の登録なし</li>}
          </ul>
        </div>
      </div>
    </section>

    <!-- 申込推移 -->
    <section class="dash-section">
      <h2 class="dash-section__title"><i class="fa-solid fa-calendar-days"></i> 日別 申込推移</h2>
      <div class="dash-trend">
        {dailyRows.length === 0 ? (
          <p class="dash-list__empty">データなし</p>
        ) : (
          dailyRows.map(r => (
            <div class="trend-bar">
              <div class="trend-bar__bar" style={`height:${pct(r.c, dailyMax)}%;`}></div>
              <span class="trend-bar__num">{r.c}</span>
              <span class="trend-bar__date">{r.d.slice(5)}</span>
            </div>
          ))
        )}
      </div>
    </section>

    <!-- 最近の申込 + チェックイン -->
    <section class="dash-section">
      <div class="dash-cols">
        <div class="dash-col">
          <h3 class="dash-col__title"><i class="fa-solid fa-clock-rotate-left"></i> 最近の申込（10件）</h3>
          {recentEntries.length === 0 ? <p class="dash-list__empty">データなし</p> : (
            <table class="dash-table">
              <thead><tr><th>ID</th><th>申込者</th><th>人数</th><th>受付済</th><th>申込日時</th></tr></thead>
              <tbody>
                {recentEntries.map(e => (
                  <tr>
                    <td><strong>#{e.id}</strong></td>
                    <td>{e.applicant_name}</td>
                    <td>{e.attendees}名</td>
                    <td>{e.checked_in_at ? <span class="badge badge--ok">✓</span> : <span class="badge badge--gray">未</span>}</td>
                    <td><small>{e.created_at}</small></td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>

        <div class="dash-col">
          <h3 class="dash-col__title"><i class="fa-solid fa-circle-check"></i> 最近のチェックイン（10件）</h3>
          {recentCheckins.length === 0 ? <p class="dash-list__empty">まだチェックインなし</p> : (
            <table class="dash-table">
              <thead><tr><th>ID</th><th>申込者</th><th>人数</th><th>受付時刻</th></tr></thead>
              <tbody>
                {recentCheckins.map(e => (
                  <tr>
                    <td><strong>#{e.id}</strong></td>
                    <td>{e.applicant_name}</td>
                    <td>{e.attendees}名</td>
                    <td><small>{e.checked_in_at}</small></td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      </div>
    </section>

    <p class="dash-foot">
      集計はリアルタイムです（ページ更新で再取得）。
      <a href="/admin/programs/">プログラム別 参加者リスト →</a>
      ／
      <a href="/admin/checkin/">QRチェックイン →</a>
    </p>
  </div>

</BaseLayout>

<style is:global>
  .dash-wrap {
    max-width: 1400px;
    margin: 0 auto;
    padding: 24px 20px 80px;
    color: var(--fsn-gray-900);
  }
  .dash-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
    padding-bottom: 14px;
    border-bottom: 2px solid var(--fsn-orange);
    flex-wrap: wrap;
    gap: 12px;
  }
  .dash-head h1 { font-size: 1.3rem; margin: 6px 0 0; color: var(--fsn-navy-deep); }
  .dash-back { font-size: 0.85rem; color: var(--fsn-gray-700); text-decoration: none; }
  .dash-back:hover { color: var(--fsn-orange); }
  .dash-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 16px; background: var(--fsn-navy-deep); color: var(--fsn-white);
    border: 0; border-radius: var(--fsn-radius-sm); cursor: pointer;
    font-size: 0.88rem; font-weight: 700;
  }
  .dash-error {
    padding: 12px 16px;
    background: #FEE2E2; color: #991B1B;
    border-radius: var(--fsn-radius-sm);
    margin-bottom: 20px;
  }

  .dash-section { margin-bottom: 32px; }
  .dash-section__title {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--fsn-navy-deep);
    margin: 0 0 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--fsn-gray-200);
  }
  .dash-section__title i { color: var(--fsn-orange); }

  /* KPIカード */
  .dash-kpi {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 12px;
  }
  @media (max-width: 1100px) { .dash-kpi { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 600px)  { .dash-kpi { grid-template-columns: repeat(2, 1fr); } }
  .kpi {
    padding: 18px 16px;
    background: var(--fsn-white);
    border: 1.5px solid var(--fsn-gray-200);
    border-radius: var(--fsn-radius-sm);
    text-align: center;
  }
  .kpi--cyan { background: var(--fsn-cyan); border-color: var(--fsn-cyan); }
  .kpi--orange { background: #FFF7ED; border-color: var(--fsn-orange); }
  .kpi__label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--fsn-gray-700);
    margin: 0 0 6px;
  }
  .kpi__num {
    font-family: var(--fsn-font-num);
    font-size: 2rem;
    font-weight: 900;
    color: var(--fsn-navy-deep);
    margin: 0;
    line-height: 1;
  }
  .kpi__sub { font-size: 0.9rem; color: var(--fsn-gray-500); font-weight: 600; }
  .kpi__unit {
    font-size: 0.78rem;
    color: var(--fsn-orange-dark);
    font-weight: 700;
    margin: 6px 0 0;
  }

  /* Day別タイル */
  .dash-day {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 700px) { .dash-day { grid-template-columns: 1fr; } }
  .day-tile {
    padding: 20px;
    border-radius: var(--fsn-radius-md);
    color: var(--fsn-white);
    text-align: center;
  }
  .day-tile--navy { background: var(--fsn-navy-deep); }
  .day-tile--orange { background: var(--fsn-orange); }
  .day-tile--both { background: linear-gradient(135deg, var(--fsn-navy-deep), var(--fsn-orange)); }
  .day-tile__day { font-size: 0.85rem; font-weight: 800; letter-spacing: 0.06em; margin: 0 0 8px; }
  .day-tile__num {
    font-family: var(--fsn-font-num);
    font-size: 2.4rem; font-weight: 900; margin: 0; line-height: 1;
  }
  .day-tile__unit { font-size: 0.95rem; font-weight: 600; margin-left: 4px; opacity: 0.9; }

  /* 2カラム */
  .dash-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 900px) { .dash-cols { grid-template-columns: 1fr; } }
  .dash-col {
    background: var(--fsn-white);
    border: 1.5px solid var(--fsn-gray-200);
    border-radius: var(--fsn-radius-sm);
    padding: 16px 18px;
  }
  .dash-col__title {
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--fsn-navy-deep);
    margin: 0 0 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .dash-col__title i { color: var(--fsn-orange); font-size: 0.85em; }
  .day-pill {
    display: inline-block;
    padding: 2px 10px;
    border-radius: var(--fsn-radius-pill);
    font-size: 0.7rem;
    font-weight: 800;
    color: #fff;
    margin-right: 6px;
  }
  .day-pill--navy { background: var(--fsn-navy-deep); }
  .day-pill--orange { background: var(--fsn-orange); }

  /* テーブル */
  .dash-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }
  .dash-table th, .dash-table td {
    border-bottom: 1px solid var(--fsn-gray-200);
    padding: 6px 8px;
    text-align: left;
  }
  .dash-table th {
    background: var(--fsn-gray-100);
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--fsn-navy-deep);
  }
  .dash-table a { color: var(--fsn-navy); text-decoration: none; font-weight: 700; }
  .dash-table a:hover { color: var(--fsn-orange); }
  .dash-table small { color: var(--fsn-gray-700); }

  /* バー */
  .bar {
    display: inline-block;
    width: 80px;
