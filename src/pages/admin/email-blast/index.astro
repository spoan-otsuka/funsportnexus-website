---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/admin.css';
import '../../../styles/apply-form.css';

export const prerender = false;

const env = Astro.locals?.runtime?.env ?? {};
const sent = Astro.url.searchParams.get('sent') || '';
const failed = Astro.url.searchParams.get('failed') || '';
const total = Astro.url.searchParams.get('total') || '';
const errorMsg = Astro.url.searchParams.get('error') || '';

// 送信履歴
let history = [];
if (env.DB) {
  try {
    history = (await env.DB.prepare(
      `SELECT id, sent_at, template, filter, subject, target_count, success_count, failed_count, testmode
       FROM email_log ORDER BY sent_at DESC LIMIT 10`
    ).all())?.results ?? [];
  } catch {}
}

// 集計
let counts = { all: 0, day1: 0, day2: 0, both: 0 };
if (env.DB) {
  try {
    const r1 = await env.DB.prepare(`SELECT COUNT(*) AS c FROM entries WHERE status='confirmed'`).first();
    counts.all = r1?.c ?? 0;

    const r2 = await env.DB.prepare(`
      SELECT
        SUM(CASE WHEN d1>0 AND d2=0 THEN 1 ELSE 0 END) AS d1only,
        SUM(CASE WHEN d2>0 AND d1=0 THEN 1 ELSE 0 END) AS d2only,
        SUM(CASE WHEN d1>0 AND d2>0 THEN 1 ELSE 0 END) AS both_d
      FROM (
        SELECT e.id,
          SUM(CASE WHEN s.day='Day1' THEN 1 ELSE 0 END) AS d1,
          SUM(CASE WHEN s.day='Day2' THEN 1 ELSE 0 END) AS d2
        FROM entries e
        LEFT JOIN entry_slots es ON es.entry_id=e.id
        LEFT JOIN slots s ON es.slot_id=s.id
        WHERE e.status='confirmed'
        GROUP BY e.id
      )
    `).first();
    counts.day1 = (r2?.d1only ?? 0) + (r2?.both_d ?? 0);
    counts.day2 = (r2?.d2only ?? 0) + (r2?.both_d ?? 0);
    counts.both = r2?.both_d ?? 0;
  } catch {}
}

// メールテンプレート
