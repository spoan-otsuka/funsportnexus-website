---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/admin.css';

export const prerender = false;

const env = Astro.locals?.runtime?.env ?? {};

let stats = { entryCount: 0, attendeeCount: 0, slotReservations: 0 };
let errorMsg = null;

if (env.DB) {
  try {
    const e = await env.DB.prepare(`SELECT COUNT(*) AS c FROM entries WHERE status = 'confirmed'`).first();
    stats.entryCount = e?.c ?? 0;
    const a = await env.DB.prepare(`SELECT COUNT(*) AS c FROM entry_attendees ea INNER JOIN entries e ON ea.entry_id = e.id WHERE e.status = 'confirmed'`).first();
    stats.attendeeCount = a?.c ?? 0;
    const s = await env.DB.prepare(`SELECT COUNT(*) AS c FROM entry_slots es INNER JOIN entries e ON es.entry_id = e.id WHERE e.status = 'confirmed'`).first();
    stats.slotReservations = s?.c ?? 0;
  } catch (e) {
    errorMsg = e.message;
  }
}
---
<BaseLayout
  title="管理 ｜ fun sport nexus 2026.12"
  description="運営用 管理画面"
  noindex={true}
  hideHeader={true}
  hideFooter={true}
>

  <div class="admin-wrap">
    <header class="admin-head">
      <h1>管理画面 ／ fun sport nexus 2026.12</h1>
      <div style="display:flex;gap:8px;">
        <a href="/" class="admin-btn admin-btn--ghost">サイトTOP</a>
        <a href="/api/admin-logout" class="admin-btn admin-btn--ghost">
          <i class="fa-solid fa-right-from-bracket"></i> ログアウト
        </a>
      </div>
    </header>

    {errorMsg && <p style="color:#b00;">エラー：{errorMsg}</p>}

    <div class="admin-stats">
      <div class="admin-stat">
        <p class="admin-stat__label">申込件数</p>
        <p class="admin-stat__num">{stats.entryCount}</p>
      </div>
      <div class="admin-stat">
        <p class="admin-stat__label">参加者数</p>
        <p class="admin-stat__num">{stats.attendeeCount}</p>
      </div>
      <div class="admin-stat">
        <p class="admin-stat__label">のべ予約数</p>
        <p class="admin-stat__num">{stats.slotReservations}</p>
      </div>
    </div>

    <div class="admin-nav">
      <a href="/admin/dashboard/" class="admin-card">
        <i class="fa-solid fa-chart-line"></i>
        <h2>ダッシュボード</h2>
        <p>申込状況の集計：KPI・プログラム充填率・参加者属性・推移グラフ。</p>
      </a>
      <a href="/admin/checkin-qr/" class="admin-card">
        <i class="fa-solid fa-qrcode"></i>
        <h2>受付QR 印刷</h2>
        <p>会場掲示用：参加者がスマホで読み取って受付できる QRコード（印刷可）。</p>
      </a>
      <a href="/admin/reception/" class="admin-card">
        <i class="fa-solid fa-user-check"></i>
        <h2>受付スタッフ用 検索チェックイン</h2>
        <p>当日 会場 運営PC専用。受付番号・名前で検索 →  Day別チェックイン。</p>
      </a>
      <a href="/admin/programs/" class="admin-card">
        <i class="fa-solid fa-clipboard-list"></i>
        <h2>プログラム別 参加者リスト</h2>
        <p>各プログラム枠の参加者を一覧表示。印刷して当日運営に。</p>
      </a>
      <a href="/admin/entries/" class="admin-card">
        <i class="fa-solid fa-list-check"></i>
        <h2>申込一覧 ／ 詳細 ／ キャンセル</h2>
        <p>申込検索・詳細表示・管理者キャンセル処理・CSV ダウンロード。</p>
      </a>
      <a href="/admin/email-blast/" class="admin-card">
        <i class="fa-solid fa-paper-plane"></i>
        <h2>メール一斉送信</h2>
        <p>リマインド（1週間前／前日）・アンケート・緊急連絡・開催中止／変更 を一括送信。</p>
      </a>
      <a href="/admin/audit-log/" class="admin-card admin-card--ghost">
        <i class="fa-solid fa-shield-halved"></i>
        <h2>監査ログ</h2>
        <p>ログイン・キャンセル・チェックイン・CSV・メール送信 の操作履歴。</p>
      </a>
      <a href="/admin/backup-print/" class="admin-card admin-card--ghost">
        <i class="fa-solid fa-file-invoice"></i>
        <h2>バックアップ印刷台帳</h2>
        <p>回線障害時の紙バックアップ。開催前日までに印刷して当日会場持参用。</p>
      </a>
      <a href="/202612orisen/lookup/" class="admin-card admin-card--ghost" target="_blank">
        <i class="fa-solid fa-search"></i>
        <h2>申込照会（公開ページ）</h2>
        <p>管理ID＋メールで申込内容を照会するページ。</p>
      </a>
    </div>

    <p class="admin-note">
      ※このページは noindex でクローラから除外。社内向けに、Cloudflare Access等でアクセス制限を推奨。
    </p>
  </div>

</BaseLayout>

<style is:global>
  .admin-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 24px;
    color: var(--fsn-gray-900);
  }
  .admin-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
    padding-bottom: 14px;
    border-bottom: 2px solid var(--fsn-orange);
  }
  .admin-head h1 { font-size: 1.4rem; margin: 0; color: var(--fsn-navy-deep); }
  .admin-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: var(--fsn-navy-deep);
    color: var(--fsn-white);
    border: 0;
    border-radius: var(--fsn-radius-sm);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 700;
  }
  .admin-btn--ghost { background: var(--fsn-white); color: var(--fsn-navy-deep); border: 1px solid var(--fsn-gray-300); }

  .admin-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  @media (max-width: 600px) { .admin-stats { grid-template-columns: 1fr; } }
  .admin-stat {
    background: var(--fsn-gray-50);
    padding: 24px;
    border-radius: var(--fsn-radius-md);
    text-align: center;
  }
  .admin-stat__label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--fsn-gray-700);
    margin: 0 0 8px;
  }
  .admin-stat__num {
    font-family: var(--fsn-font-num);
    font-size: 2.4rem;
    font-weight: 900;
    color: var(--fsn-orange-dark);
    margin: 0;
    line-height: 1;
  }

  .admin-nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  @media (max-width: 600px) { .admin-nav { grid-template-columns: 1fr; } }
  .admin-card {
    display: block;
    padding: 24px;
    background: var(--fsn-white);
    border: 1.5px solid var(--fsn-gray-200);
    border-radius: var(--fsn-radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .admin-card:hover {
    border-color: var(--fsn-orange);
    transform: translateY(-2px);
    box-shadow: var(--fsn-shadow-sm);
  }
  .admin-card--ghost {
    background: var(--fsn-gray-50);
    border-style: dashed;
    border-color: var(--fsn-gray-300);
  }
  .admin-card--ghost h2 { color: var(--fsn-gray-700); }
  .admin-card--ghost i { color: var(--fsn-gray-500); }
  .admin-card--ghost:hover { border-style: solid; }
  .admin-card i {
    font-size: 1.5rem;
    color: var(--fsn-orange);
    margin-bottom: 8px;
  }
  .admin-card h2 {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--fsn-navy-deep);
    margin: 0 0 6px;
  }
  .admin-card p {
    font-size: 0.85rem;
    color: var(--fsn-gray-700);
    margin: 0;
    line-height: 1.6;
  }

  .admin-note {
    font-size: 0.78rem;
    color: var(--fsn-gray-500);
    margin: 24px 0 0;
    padding-top: 16px;
    border-top: 1px dashed var(--fsn-gray-200);
  }
</style>
