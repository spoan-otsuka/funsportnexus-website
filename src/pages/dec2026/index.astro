---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/dec2026.css';

const programs = [
  { code: 'panshoku',     name: 'スポあんぱん食い競走', time: '10:00 ／ 15:00 開始', venue: '中央広場',       day: 'Day1 ／ Day2', icon: 'fa-bread-slice',          featured: true },
  { code: 'baseball5',    name: 'Baseball5 体験',       time: '10:00 - 15:00 通し',   venue: '第1体育室',     day: 'Day1',          icon: 'fa-baseball-bat-ball' },
  { code: 'basket',       name: 'バスケットボール',     time: '10:00 - 15:00 通し',   venue: '第3体育室',     day: 'Day1',          icon: 'fa-basketball' },
  { code: 'legit',        name: 'Legit ダンス',         time: '10:00 ／ 12:00 ／ 14:00', venue: '第4体育室',  day: 'Day1',          icon: 'fa-music' },
  { code: 'judo',         name: '柔道体験',             time: '10:00 ／ 12:00 ／ 14:00', venue: '第5体育室',  day: 'Day1',          icon: 'fa-hand-fist' },
  { code: 'pickle',       name: 'ピックルボール',       time: '10:00 - 15:00 通し',   venue: '第2体育室',     day: 'Day1',          icon: 'fa-table-tennis-paddle-ball' },
  { code: 'boccia',       name: 'ボッチャ',             time: '自由参加 ／ 終日通し', venue: '体育室エントランス', day: 'Day1',     icon: 'fa-bullseye' },
  { code: 'ycap',         name: 'YCAP チームビルディング', time: '10:00 ／ 12:00 ／ 14:00', venue: 'YCAPエリア', day: 'Day1 ／ Day2', icon: 'fa-people-group' },
  { code: 'kakekko',      name: 'かけっこ教室',         time: '11:00 ／ 14:00',       venue: '第1体育室',     day: 'Day2',          icon: 'fa-person-running' },
  { code: 'oni',          name: '鬼ごっこ',             time: '12:00 - 15:00 通し',   venue: '第2体育室',     day: 'Day2',          icon: 'fa-children' },
  { code: 'fencing',      name: 'フェンシング体験',     time: '10:00 ／ 12:00 ／ 14:00', venue: '第4体育室',  day: 'Day2',          icon: 'fa-khanda' },
  { code: 'dip',          name: 'DIP（ミュージックドリブル）', time: '11:00 ／ 13:00 ／ 15:00', venue: '第5体育室', day: 'Day2',    icon: 'fa-record-vinyl' },
  { code: 'closing',      name: '閉会セレモニー＋演劇', time: '13:00 - 15:00',        venue: '小ホール',       day: 'Day2',          icon: 'fa-masks-theater', special: true },
];
---
<BaseLayout
  title="fun sport nexus 2026.12"
  description="2026年12月19日（土）・20日（日）開催。国立オリンピック記念青少年総合センターで、明るく、楽しく、人と人をつなぐ2日間。"
>

  <!-- Hero -->
  <section class="dec-hero">
    <div class="dec-hero__bg" style="background-image: url('/logo-fsn.png');"></div>
    <div class="dec-hero__overlay"></div>
    <div class="dec-hero__inner">
      <p class="dec-hero__label">FUN SPORT NEXUS  ／  2026 WINTER</p>
      <h1 class="dec-hero__catch">明るく、楽しく、<br>人と人をつなぐ。</h1>
      <p class="dec-hero__lead">
        12月19日と20日の2日間、国立オリンピック記念青少年総合センターで、<br>
        「fun sport nexus」を、ひらきます。
      </p>
      <div class="dec-hero__meta">
        <span class="dec-hero__meta-item"><i class="fa-solid fa-calendar-days"></i> 2026.12.19（土） - 20（日）</span>
        <span class="dec-hero__meta-item"><i class="fa-solid fa-location-dot"></i> 国立オリンピック記念青少年総合センター</span>
        <span class="dec-hero__meta-item dec-hero__meta-item--free"><i class="fa-solid fa-ticket"></i> 参加費無料</span>
      </div>
      <p style="margin: 24px 0 0;">
        <a href="/dec2026/apply/" class="dec-btn dec-btn--primary dec-btn--lg">
          <i class="fa-solid fa-pen-to-square"></i>
          参加を申し込む
        </a>
      </p>
    </div>
  </section>

  <!-- HIGHLIGHT PROGRAMS -->
  <section class="dec-section">
    <div class="dec-section__inner">
      <p class="dec-section__label dec-section__label--orange">PROGRAMS</p>
      <h2 class="dec-section__title">2日間で楽しめる、<br>多彩なプログラム</h2>
      <p class="dec-section__lead">
        ぱん食い競走、Baseball5、ダンス、ボッチャ、フェンシングなど、<br>
        多種多様なスポーツや文化を、無料で体験できます。
      </p>

      <div class="dec-stats">
        <div class="dec-stat">
          <span class="dec-stat__num">15<span class="dec-stat__plus">+</span></span>
          <span class="dec-stat__label">プログラム</span>
        </div>
        <div class="dec-stat">
          <span class="dec-stat__num">2</span>
          <span class="dec-stat__label">日間 開催</span>
        </div>
        <div class="dec-stat">
          <span class="dec-stat__num dec-stat__num--text">無料</span>
          <span class="dec-stat__label">参加費</span>
        </div>
      </div>

      <div class="dec-progmini__grid">
        {programs.map(p => (
          <a href="/dec2026/programs/" class={`dec-progmini ${p.featured ? 'dec-progmini--featured' : ''} ${p.special ? 'dec-progmini--special' : ''}`}>
            <span class="dec-progmini__image"></span>
            <span class="dec-progmini__name">{p.name}</span>
            <span class="dec-progmini__meta">
              <span class="dec-progmini__time"><i class="fa-regular fa-clock"></i> {p.time}</span>
              <span class="dec-progmini__venue"><i class="fa-solid fa-location-dot"></i> {p.venue}</span>
            </span>
            <span class="dec-progmini__day">{p.day}</span>
          </a>
        ))}
      </div>

      <p style="text-align: center; margin-top: 32px;">
        <a href="/dec2026/programs/" class="dec-link">
          プログラム詳細を見る
          <i class="fa-solid fa-arrow-right"></i>
        </a>
      </p>
    </div>
  </section>

  <!-- TIMETABLE 時間スロット式 -->
  <section class="dec-section dec-section--tint">
    <div class="dec-section__inner">
      <p class="dec-section__label">TIMETABLE</p>
      <h2 class="dec-section__title">プログラム スケジュール</h2>
      <p class="dec-section__lead">
        各時間帯ごとに、開催プログラムを、一覧でご紹介します。<br>
        ※現時点の仮入れ。最終確定は、各団体との調整後に、ご案内いたします。
      </p>

      <!-- DAY 1 -->
      <div class="ttslot-day">
        <div class="ttslot-day__head ttslot-day__head--navy">
          <span class="ttslot-day__num">DAY 1</span>
          <span class="ttslot-day__date">12月19日（土）</span>
          <span class="ttslot-day__theme">スポーツの源流</span>
        </div>

        <div class="ttslot-row">
          <div class="ttslot-time">
            <span class="ttslot-time__main">10:00</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--orange"><i class="fa-solid fa-bread-slice"></i> ぱん食い競走<small>中央広場</small></span>
            <span class="ttslot-card ttslot-card--pink"><i class="fa-solid fa-music"></i> Legit ダンス ①<small>第4体育室</small></span>
            <span class="ttslot-card ttslot-card--purple"><i class="fa-solid fa-people-group"></i> YCAP ①<small>YCAPエリア</small></span>
            <span class="ttslot-card ttslot-card--blue ttslot-card--allday"><i class="fa-solid fa-baseball-bat-ball"></i> Baseball5<small>第1体育室 ／ 終日</small></span>
            <span class="ttslot-card ttslot-card--orange-soft ttslot-card--allday"><i class="fa-solid fa-table-tennis-paddle-ball"></i> レク協会<small>第2体育室 ／ 終日</small></span>
            <span class="ttslot-card ttslot-card--yellow ttslot-card--allday"><i class="fa-solid fa-basketball"></i> バスケ<small>第3体育室 ／ 終日</small></span>
            <span class="ttslot-card ttslot-card--blue ttslot-card--allday"><i class="fa-solid fa-bullseye"></i> ボッチャ・将棋<small>体育室エントランス ／ 終日</small></span>
          </div>
        </div>

        <div class="ttslot-row">
          <div class="ttslot-time">
            <span class="ttslot-time__main">11:00</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--green"><i class="fa-solid fa-hand-fist"></i> 柔道 ①<small>第5体育室</small></span>
          </div>
        </div>

        <div class="ttslot-row">
          <div class="ttslot-time">
            <span class="ttslot-time__main">12:00</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--pink"><i class="fa-solid fa-music"></i> Legit ダンス ②<small>第4体育室</small></span>
            <span class="ttslot-card ttslot-card--purple"><i class="fa-solid fa-people-group"></i> YCAP ②<small>YCAPエリア</small></span>
          </div>
        </div>

        <div class="ttslot-row">
          <div class="ttslot-time">
            <span class="ttslot-time__main">13:00</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--green"><i class="fa-solid fa-hand-fist"></i> 柔道 ②<small>第5体育室</small></span>
          </div>
        </div>

        <div class="ttslot-row">
          <div class="ttslot-time">
            <span class="ttslot-time__main">14:00</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--pink"><i class="fa-solid fa-music"></i> Legit ダンス ③<small>第4体育室</small></span>
            <span class="ttslot-card ttslot-card--purple"><i class="fa-solid fa-people-group"></i> YCAP ③<small>YCAPエリア</small></span>
          </div>
        </div>

        <div class="ttslot-row">
          <div class="ttslot-time">
            <span class="ttslot-time__main">15:00</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--orange"><i class="fa-solid fa-bread-slice"></i> ぱん食い競走<small>中央広場</small></span>
            <span class="ttslot-card ttslot-card--green"><i class="fa-solid fa-hand-fist"></i> 柔道 ③<small>第5体育室</small></span>
          </div>
        </div>

        <div class="ttslot-row ttslot-row--special">
          <div class="ttslot-time ttslot-time--special">
            <span class="ttslot-time__main">16:30</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--special"><i class="fa-solid fa-microphone-lines"></i> 特別セミナー（90分）<small>センター棟 ／ 基調講演＋WS＋交流会</small></span>
          </div>
        </div>
      </div>

      <!-- DAY 2 -->
      <div class="ttslot-day">
        <div class="ttslot-day__head ttslot-day__head--orange">
          <span class="ttslot-day__num">DAY 2</span>
          <span class="ttslot-day__date">12月20日（日）</span>
          <span class="ttslot-day__theme">体験会 ＋ 大会要素</span>
        </div>

        <div class="ttslot-row">
          <div class="ttslot-time">
            <span class="ttslot-time__main">10:00</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--orange"><i class="fa-solid fa-bread-slice"></i> ぱん食い競走<small>中央広場</small></span>
            <span class="ttslot-card ttslot-card--orange"><i class="fa-solid fa-khanda"></i> フェンシング ①<small>第4体育室</small></span>
            <span class="ttslot-card ttslot-card--purple"><i class="fa-solid fa-people-group"></i> YCAP ①<small>YCAPエリア</small></span>
          </div>
        </div>

        <div class="ttslot-row">
          <div class="ttslot-time">
            <span class="ttslot-time__main">11:00</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--green"><i class="fa-solid fa-person-running"></i> かけっこ教室 ①<small>第1体育室</small></span>
            <span class="ttslot-card ttslot-card--yellow"><i class="fa-solid fa-record-vinyl"></i> DIP ①<small>第5体育室</small></span>
          </div>
        </div>

        <div class="ttslot-row">
          <div class="ttslot-time">
            <span class="ttslot-time__main">12:00</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--orange"><i class="fa-solid fa-khanda"></i> フェンシング ②<small>第4体育室</small></span>
            <span class="ttslot-card ttslot-card--purple"><i class="fa-solid fa-people-group"></i> YCAP ②<small>YCAPエリア</small></span>
            <span class="ttslot-card ttslot-card--yellow ttslot-card--allday"><i class="fa-solid fa-children"></i> 鬼ごっこ<small>第2体育室 ／ 〜15:00</small></span>
          </div>
        </div>

        <div class="ttslot-row">
          <div class="ttslot-time">
            <span class="ttslot-time__main">13:00</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--orange"><i class="fa-solid fa-bread-slice"></i> ぱん食い競走<small>中央広場</small></span>
            <span class="ttslot-card ttslot-card--yellow"><i class="fa-solid fa-record-vinyl"></i> DIP ②<small>第5体育室</small></span>
            <span class="ttslot-card ttslot-card--navy"><i class="fa-solid fa-drum"></i> 太鼓体験会<small>小ホール</small></span>
          </div>
        </div>

        <div class="ttslot-row">
          <div class="ttslot-time">
            <span class="ttslot-time__main">14:00</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--green"><i class="fa-solid fa-person-running"></i> かけっこ教室 ②<small>第1体育室</small></span>
            <span class="ttslot-card ttslot-card--orange"><i class="fa-solid fa-khanda"></i> フェンシング ③<small>第4体育室</small></span>
            <span class="ttslot-card ttslot-card--purple"><i class="fa-solid fa-people-group"></i> YCAP ③<small>YCAPエリア</small></span>
          </div>
        </div>

        <div class="ttslot-row">
          <div class="ttslot-time">
            <span class="ttslot-time__main">15:00</span>
            <span class="ttslot-time__sub">スタート</span>
          </div>
          <div class="ttslot-progs">
            <span class="ttslot-card ttslot-card--yellow"><i class="fa-solid fa-record-vinyl"></i> DIP ③<small>第5体育室</small></span>
            <span class="ttslot-card ttslot-card--navy"><i class="fa-solid fa-masks-theater"></i> 太鼓発表会<small>小ホール</small></span>
          </div>
        </div>
      </div>

      <!-- 凡例 -->
      <div class="ttslot-legend">
        <p class="ttslot-legend__label">凡例</p>
        <div class="ttslot-legend__items">
          <span class="ttslot-legend__item"><span class="ttslot-legend__dot ttslot-legend__dot--orange"></span>ぱん食い・フェンシング</span>
          <span class="ttslot-legend__item"><span class="ttslot-legend__dot ttslot-legend__dot--pink"></span>ダンス</span>
          <span class="ttslot-legend__item"><span class="ttslot-legend__dot ttslot-legend__dot--green"></span>かけっこ・柔道</span>
          <span class="ttslot-legend__item"><span class="ttslot-legend__dot ttslot-legend__dot--yellow"></span>DIP・鬼ごっこ・バスケ</span>
          <span class="ttslot-legend__item"><span class="ttslot-legend__dot ttslot-legend__dot--purple"></span>YCAP</span>
          <span class="ttslot-legend__item"><span class="ttslot-legend__dot ttslot-legend__dot--blue"></span>Baseball5・ボッチャ</span>
          <span class="ttslot-legend__item"><span class="ttslot-legend__dot ttslot-legend__dot--navy"></span>太鼓・受付</span>
          <span class="ttslot-legend__item"><span class="ttslot-legend__dot ttslot-legend__dot--special"></span>セミナー</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SPECIAL SEMINAR -->
  <section class="dec-section">
    <div class="dec-section__inner">
      <p class="dec-section__label dec-section__label--orange">SPECIAL SEMINAR</p>
      <h2 class="dec-section__title">特別セミナー</h2>
      <p class="dec-section__lead">
        Day1の夕方に、スポーツ・教育の第一線で活躍する方々を、お招きします。<br>
        基調講演と、参加型ワークショップを、おこないます。
      </p>

      <div class="dec-seminar__info">
        <div class="dec-seminar__info-item">
          <span class="dec-seminar__info-label">日時</span>
          <span class="dec-seminar__info-value">12月19日（土）16:30 - 18:00（90分）</span>
        </div>
        <div class="dec-seminar__info-item">
          <span class="dec-seminar__info-label">会場</span>
          <span class="dec-seminar__info-value">オリセン センター棟 内</span>
        </div>
        <div class="dec-seminar__info-item">
          <span class="dec-seminar__info-label">構成</span>
          <span class="dec-seminar__info-value">基調講演 ＋ ワークショップ ＋ 交流会</span>
        </div>
      </div>

      <h3 class="dec-seminar__sub">登壇予定（敬称略）</h3>
      <div class="dec-seminar__grid">
        <article class="dec-seminar-card">
          <div class="dec-seminar-card__photo" style="background-image: url('/logo-fsn.png');"></div>
          <div class="dec-seminar-card__body">
            <p class="dec-seminar-card__name">益子 直美</p>
            <p class="dec-seminar-card__title">一般社団法人 監督が怒ってはいけない大会  代表理事</p>
          </div>
        </article>
        <article class="dec-seminar-card">
          <div class="dec-seminar-card__photo" style="background-image: url('/logo-fsn.png');"></div>
          <div class="dec-seminar-card__body">
            <p class="dec-seminar-card__name">為末 大</p>
            <p class="dec-seminar-card__title">いっ"ぱん"社団法人 ぱん食い競走協会  会長 ／ 元 世界陸上 銅メダリスト</p>
          </div>
        </article>
        <article class="dec-seminar-card">
          <div class="dec-seminar-card__photo" style="background-image: url('/logo-fsn.png');"></div>
          <div class="dec-seminar-card__body">
            <p class="dec-seminar-card__name">田丸 尚稔</p>
            <p class="dec-seminar-card__title">一般財団法人 渋谷区スポーツ協会  専務理事</p>
          </div>
        </article>
        <article class="dec-seminar-card">
          <div class="dec-seminar-card__photo dec-seminar-card__photo--tba">
            <i class="fa-solid fa-user-plus"></i>
          </div>
          <div class="dec-seminar-card__body">
            <p class="dec-seminar-card__name">調整中</p>
            <p class="dec-seminar-card__title">スポーツ界・教育界の第一線の方々を、お招き予定です</p>
          </div>
        </article>
      </div>
      <p class="dec-seminar__note">※登壇者・内容は、確定次第ご案内いたします。</p>
    </div>
  </section>

  <!-- ACCESS -->
  <section class="dec-section dec-section--tint">
    <div class="dec-section__inner">
      <p class="dec-section__label">ACCESS</p>
      <h2 class="dec-section__title">会場のご案内</h2>

      <div class="dec-access__layout">
        <div class="dec-access__info">
          <p class="dec-access__name">国立オリンピック記念<br>青少年総合センター</p>
          <p class="dec-access__row">
            <i class="fa-solid fa-location-dot"></i>
            〒151-0052<br>東京都 渋谷区 代々木神園町 3-1
          </p>
          <p class="dec-access__row">
            <i class="fa-solid fa-train-subway"></i>
            小田急線「参宮橋駅」 徒歩7分
          </p>
          <p class="dec-access__row">
            <i class="fa-solid fa-train-subway"></i>
            東京メトロ千代田線「代々木公園駅」 徒歩10分
          </p>
          <p class="dec-access__row">
            <i class="fa-solid fa-bus"></i>
            京王バス「オリンピックセンター」下車すぐ
          </p>
          <p style="margin-top: 24px;">
            <a href="/dec2026/access/" class="dec-link">
              アクセスの詳細を見る
              <i class="fa-solid fa-arrow-right"></i>
            </a>
          </p>
        </div>
        <div class="dec-access__map">
          <iframe
