---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/202612orisen.css';
import '../../../styles/apply-form.css';

export const prerender = false;
---
<BaseLayout
  title="ご来場受付 ｜ fun sport nexus 2026.12"
  description="会場受付：当日参加の方はこちらから、お申し込みください。"
  noindex={true}
>

  <section class="dec-sub-hero">
    <div class="dec-sub-hero__bg"></div>
    <div class="dec-sub-hero__inner">
      <p class="dec-sub-hero__label">CHECK-IN</p>
      <h1 class="dec-sub-hero__title">ご来場受付</h1>
      <p class="dec-sub-hero__lead">
        ご来場、ありがとうございます。<br>
        以下から、お進みください。
      </p>
    </div>
  </section>

  <section class="ap-section">
    <div class="ap-section__inner" style="max-width: 760px;">

      <!-- 当日 ご参加の方（メイン） -->
      <div class="ap-step">
        <h2 class="ap-step__title"><span class="ap-step__num">1</span> 当日 ご参加の方</h2>
        <p class="ap-step__desc">
          事前のお申し込みなしで、ご来場された方は、その場で、お申し込みいただけます。<br>
          ※当日 空きがあるプログラムのみ、ご参加可能です。
        </p>
        <a href="/202612orisen/apply/?walkin=1" class="ck-big-btn ck-big-btn--orange">
          <i class="fa-solid fa-pen-to-square"></i>
          <span>当日申込フォームへ進む</span>
        </a>
      </div>

      <!-- 事前にお申し込み済の方 -->
      <div class="ap-step">
        <h2 class="ap-step__title"><span class="ap-step__num">2</span> 事前にお申し込みの方</h2>
        <div class="ck-pre-guide">
          <p class="ck-pre-guide__lead">
            <i class="fa-solid fa-envelope-open-text"></i>
            <strong>お申込み完了メール</strong>を、ご確認ください
          </p>
          <ol class="ck-steps">
            <li>
              <span class="ck-steps__num">1</span>
              <div>
                <p class="ck-steps__title">受信箱から、メールを、開きます</p>
                <p class="ck-steps__hint">件名：「【受付完了】fun sport nexus 2026.12 参加申込」</p>
              </div>
            </li>
            <li>
              <span class="ck-steps__num">2</span>
              <div>
                <p class="ck-steps__title">本文中の<strong>QRコードURL</strong>を、タップします</p>
                <p class="ck-steps__hint">「当日受付用 QRコード」と書かれた、URLです</p>
              </div>
            </li>
            <li>
              <span class="ck-steps__num">3</span>
              <div>
                <p class="ck-steps__title">受付画面で、お手続きを、お進めください</p>
                <p class="ck-steps__hint">ぱん食い競走への参加意思のご確認 → チェックイン完了</p>
              </div>
            </li>
          </ol>
        </div>

        <details class="ck-fallback">
          <summary>メールが、お手元にない場合は、こちら</summary>
          <div class="ck-fallback__body">
            <p><strong>管理ID（受付番号）</strong>と、ご登録の<strong>メールアドレス</strong>で、照会できます。</p>
            <a href="/202612orisen/lookup/" class="ap-submit__btn" style="display:inline-flex;text-decoration:none;font-size:0.95rem;padding:12px 26px;">
              <i class="fa-solid fa-search"></i> 管理ID＋メールで照会
            </a>
          </div>
        </details>

        <details class="ck-fallback">
          <summary>紙のQRコードを、お持ちの方は、こちら</summary>
          <div class="ck-fallback__body">
            <p>印刷したQRなどを、お持ちの場合は、カメラで、読み取れます。</p>
            <button type="button" id="start-scan" class="ck-mini-btn">
              <i class="fa-solid fa-camera"></i>
              <span data-label>カメラを起動してQRを読み取る</span>
            </button>
            <div id="scanner" class="ck-scanner" hidden>
              <video id="video" playsinline muted></video>
              <canvas id="canvas" style="display:none;"></canvas>
              <div class="ck-scanner__overlay">
                <div class="ck-scanner__frame"></div>
                <p class="ck-scanner__hint">QRを枠内に映してください</p>
              </div>
            </div>
            <div id="status" class="ck-status" hidden></div>
          </div>
        </details>
      </div>

      <p class="ck-help">
        ご不明な点は、お近くの<strong>受付スタッフ</strong>に、お声がけください。
      </p>

    </div>
  </section>

  <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
  <script is:inline>
    (function() {
      const startBtn = document.getElementById('start-scan');
      if (!startBtn) return;
      const scannerEl = document.getElementById('scanner');
      const video = document.getElementById('video');
      const canvas = document.getElementById('canvas');
      const ctx = canvas.getContext('2d', { willReadFrequently: true });
      const statusEl = document.getElementById('status');
      const label = startBtn.querySelector('[data-label]');
      let stream = null;
      let scanning = false;

      function setStatus(msg, type) {
        statusEl.hidden = false;
        statusEl.textContent = msg;
        statusEl.className = 'ck-status ' + (type ? 'ck-status--' + type : '');
      }

      async function start() {
        try {
          stream = await navigator.mediaDevices.getUserMedia({
            video: { facingMode: 'environment' },
            audio: false,
          });
          video.srcObject = stream;
          await video.play();
          scannerEl.hidden = false;
          scanning = true;
          label.textContent = 'スキャン中… 停止';
          setStatus('QRを枠内に映してください', 'scanning');
          tick();
        } catch (e) {
          setStatus('カメラを起動できません: ' + e.message, 'error');
        }
      }
      function stop() {
        scanning = false;
        if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
        video.srcObject = null;
        scannerEl.hidden = true;
        label.textContent = 'カメラを起動してQRを読み取る';
        statusEl.hidden = true;
      }
      startBtn.addEventListener('click', () => { if (scanning) stop(); else start(); });

      function tick() {
        if (!scanning) return;
        if (video.readyState === video.HAVE_ENOUGH_DATA) {
          canvas.width = video.videoWidth;
          canvas.height = video.videoHeight;
          ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
          const img = ctx.getImageData(0, 0, canvas.width, canvas.height);
          const code = jsQR(img.data, img.width, img.height, { inversionAttempts: 'dontInvert' });
          if (code && code.data) {
            let url = code.data;
            const m = url.match(/[?&]t=([^&]+)/);
            const token = m ? decodeURIComponent(m[1]) : '';
            if (token) {
              scanning = false;
              setStatus('受付情報を確認中…', 'success');
              if (navigator.vibrate) navigator.vibrate(150);
              setTimeout(() => {
                location.href = '/202612orisen/qr/?t=' + encodeURIComponent(token) + '&from=checkin';
              }, 300);
              return;
            } else if (/^https?:/.test(url) && url.includes('/qr/')) {
              scanning = false;
              setStatus('受付情報を確認中…', 'success');
              if (navigator.vibrate) navigator.vibrate(150);
              // 会場経由のフラグ付与
              const sep = url.includes('?') ? '&' : '?';
              const finalUrl = url + sep + 'from=checkin';
              setTimeout(() => { location.href = finalUrl; }, 300);
              return;
            }
          }
        }
        requestAnimationFrame(tick);
      }
    })();
  </script>

</BaseLayout>

<style is:global>
  /* 大ボタン */
  .ck-big-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    padding: 22px 24px;
    border-radius: var(--fsn-radius-md);
    color: var(--fsn-white);
    border: 0;
    cursor: pointer;
    font-size: 1.1rem;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 6px 18px rgba(0,0,0,0.15);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .ck-big-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    color: var(--fsn-white);
  }
  .ck-big-btn i { font-size: 1.3em; }
  .ck-big-btn--orange { background: linear-gradient(135deg, var(--fsn-orange), var(--fsn-orange-dark)); }

  /* 小ボタン */
  .ck-mini-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: var(--fsn-navy-deep);
    color: var(--fsn-white);
    border: 0;
    border-radius: var(--fsn-radius-pill);
    font-size: 0.92rem;
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
  }
  .ck-mini-btn:hover { background: #050d2e; color: var(--fsn-white); }

  /* 事前申込ガイド */
  .ck-pre-guide {
    padding: 24px;
    background: var(--fsn-gray-50);
    border-radius: var(--fsn-radius-md);
    border-left: 4px solid var(--fsn-navy-deep);
  }
  .ck-pre-guide__lead {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--fsn-navy-deep);
    margin: 0 0 18px;
  }
  .ck-pre-guide__lead i { color: var(--fsn-orange); font-size: 1.3em; }

  .ck-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .ck-steps li {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 14px;
    align-items: start;
  }
  .ck-steps__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--fsn-orange);
    color: var(--fsn-white);
    border-radius: 50%;
    font-family: var(--fsn-font-num);
    font-weight: 900;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .ck-steps__title {
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--fsn-navy-deep);
    margin: 4px 0 4px;
    line-height: 1.5;
  }
  .ck-steps__hint {
    font-size: 0.82rem;
    color: var(--fsn-gray-700);
    margin: 0;
    line-height: 1.6;
  }

  /* スキャナー（フォールバック内） */
  .ck-scanner {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 360px;
    margin: 12px auto 0;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
  }
  .ck-scanner video { width: 100%; height: 100%; object-fit: cover; }
  .ck-scanner__overlay {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    pointer-events: none;
  }
  .ck-scanner__frame {
    width: 70%;
    aspect-ratio: 1 / 1;
    border: 3px solid var(--fsn-orange);
    border-radius: 12px;
    box-shadow: 0 0 0 9999px rgba(0,0,0,0.4);
  }
  .ck-scanner__hint {
    position: absolute;
    bottom: 12px;
    color: #fff;
    background: rgba(0,0,0,0.55);
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 0.78rem;
    margin: 0;
  }

  .ck-status {
    margin-top: 10px;
    padding: 10px 12px;
    background: var(--fsn-gray-100);
    color: var(--fsn-gray-700);
    border-radius: var(--fsn-radius-sm);
    text-align: center;
    font-size: 0.88rem;
    font-weight: 600;
  }
  .ck-status--scanning { background: #DBEAFE; color: #1E40AF; }
  .ck-status--success { background: #DCFCE7; color: #166534; }
  .ck-status--error { background: #FEE2E2; color: #991B1B; }

  /* フォールバック */
  .ck-fallback {
    margin-top: 12px;
    background: var(--fsn-gray-50);
    border-radius: var(--fsn-radius-sm);
    overflow: hidden;
  }
  .ck-fallback summary {
    padding: 14px 18px;
    cursor: pointer;
    list-style: none;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--fsn-orange-dark);
    position: relative;
  }
  .ck-fallback summary::-webkit-details-marker { display: none; }
  .ck-fallback summary::after {
    content: "▾";
    position: absolute;
    right: 18px;
    transition: transform 0.15s;
  }
  .ck-fallback[open] summary::after { transform: rotate(180deg); }
  .ck-fallback__body {
    padding: 0 18px 18px;
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--fsn-gray-700);
  }
  .ck-fallback__body p { margin: 0 0 12px; }

  .ck-help {
    text-align: center;
    font-size: 0.88rem;
    color: var(--fsn-gray-700);
    margin: 24px 0 0;
  }
</style>
