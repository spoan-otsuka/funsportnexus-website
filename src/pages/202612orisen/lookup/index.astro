---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/202612orisen.css';
import '../../../styles/apply-form.css';

export const prerender = false;

const env = Astro.locals?.runtime?.env ?? {};
const idParam = Astro.url.searchParams.get('id') || '';
const emailParam = Astro.url.searchParams.get('email') || '';
const checkinDone = Astro.url.searchParams.get('checkin_done') === '1';
const attSaved = Astro.url.searchParams.get('saved') === '1';

let entry = null;
let attendees = [];
let entrySlots = [];
let lookupError = null;
let notFound = false;

if (idParam && emailParam && env.DB) {
  try {
    const e = await env.DB.prepare(
      'SELECT * FROM entries WHERE id = ? AND LOWER(email) = LOWER(?)'
    ).bind(parseInt(idParam, 10), emailParam.trim()).first();
    if (e) {
      entry = e;
      const a = await env.DB.prepare(
        'SELECT * FROM entry_attendees WHERE entry_id = ? ORDER BY position'
      ).bind(e.id).all();
      attendees = a?.results ?? [];
      const s = await env.DB.prepare(`
        SELECT es.id AS entry_slot_id, es.attendee_id, es.attended,
               s.id AS slot_id, s.program_name, s.day, s.time_start, s.time_end, s.venue
        FROM entry_slots es
        INNER JOIN slots s ON es.slot_id = s.id
        WHERE es.entry_id = ?
        ORDER BY s.day, s.time_start
      `).bind(e.id).all();
      entrySlots = s?.results ?? [];
    } else {
      notFound = true;
    }
  } catch (e) {
    lookupError = e.message;
  }
}

const slotsByAttendee = {};
for (const s of entrySlots) {
  const k = s.attendee_id || 0;
  if (!slotsByAttendee[k]) slotsByAttendee[k] = [];
  slotsByAttendee[k].push(s);
}

// 当日（JST）の Day 判定
const jst = new Date(Date.now() + 9 * 3600 * 1000);
const ymd = jst.toISOString().slice(0, 10);
let todayDay = null;
if (ymd === '2026-12-19') todayDay = 'Day1';
else if (ymd === '2026-12-20') todayDay = 'Day2';

// 日別チェックイン状況の取得
let dayCheckins = {};
if (entry && env.DB) {
  try {
    const cks = (await env.DB.prepare(
      `SELECT day, checked_at FROM entry_checkins WHERE entry_id = ?`
    ).bind(entry.id).all())?.results ?? [];
    for (const c of cks) dayCheckins[c.day] = c.checked_at;
  } catch {}
}

// 申込している日を判別
const reservedDays = new Set(entrySlots.map(s => s.day));
const hasDay1 = reservedDays.has('Day1');
const hasDay2 = reservedDays.has('Day2');

// 今日チェックイン済かどうか
const todayChecked = todayDay ? !!dayCheckins[todayDay] : false;
// すべての参加日がチェックイン済か
const allDaysChecked =
  (hasDay1 ? !!dayCheckins['Day1'] : true) &&
  (hasDay2 ? !!dayCheckins['Day2'] : true);
---
<BaseLayout
  title="申込内容の確認 ｜ fun sport nexus 2026.12"
  description="管理IDとメールアドレスで、お申込み内容を、ご確認いただけます。"
  noindex={true}
>

  <section class="dec-sub-hero">
    <div class="dec-sub-hero__bg"></div>
    <div class="dec-sub-hero__inner">
      <p class="dec-sub-hero__label">LOOKUP</p>
      <h1 class="dec-sub-hero__title">申込内容の確認</h1>
      <p class="dec-sub-hero__lead">
        お申込み完了メールに記載の<strong>管理ID</strong>と、<br>
        ご登録のメールアドレスで、内容を、ご確認いただけます。
      </p>
    </div>
  </section>

  <section class="ap-section">
    <div class="ap-section__inner" style="max-width: 760px;">
      <form class="ap-form" method="GET">
        <div class="ap-step">
          <h2 class="ap-step__title"><span class="ap-step__num">!</span> 管理ID＋メールで照会</h2>
          {notFound && (
            <div class="ap-error-banner">
              <i class="fa-solid fa-circle-exclamation"></i>
              該当のお申込みが、見つかりませんでした。<br>
              管理IDとメールアドレスを、ご確認ください。
            </div>
          )}
          {lookupError && (
            <div class="ap-error-banner">エラー：{lookupError}</div>
          )}

          <div class="ap-grid">
            <div class="ap-field">
              <label for="id" class="ap-label">
                管理ID <span class="ap-required">必須</span>
              </label>
              <input id="id" name="id" type="number" required value={idParam}
                placeholder="例：12" class="ap-input" />
            </div>
            <div class="ap-field">
              <label for="email" class="ap-label">
                メールアドレス <span class="ap-required">必須</span>
              </label>
              <input id="email" name="email" type="email" required value={emailParam}
                placeholder="お申込み時のメール" class="ap-input" />
            </div>
          </div>

          <div class="ap-submit" style="margin-top:24px;">
            <button type="submit" class="ap-submit__btn">
              <i class="fa-solid fa-search"></i> 照会する
            </button>
          </div>
        </div>

        {entry && (
          <>
          <div class="ap-step">
            <h2 class="ap-step__title"><span class="ap-step__num">1</span> お申込み者（代表者）情報</h2>
            <dl class="lk-meta">
              <div><dt>管理ID</dt><dd><strong>#{entry.id}</strong></dd></div>
              <div><dt>お名前</dt><dd>{entry.applicant_name} 様（{entry.applicant_furigana}）</dd></div>
              <div><dt>メール</dt><dd>{entry.email}</dd></div>
              <div><dt>お電話</dt><dd>{entry.tel}</dd></div>
              <div><dt>申込日時</dt><dd>{entry.created_at}</dd></div>
            </dl>
          </div>

          <div class="ap-step">
            <h2 class="ap-step__title"><span class="ap-step__num">2</span> ご参加者（{entry.attendees}名）／ 各プログラム 出欠</h2>
            <p class="ap-step__desc">
              <strong>欠席</strong>されるプログラムがある場合は、チェックを、外してください。<br>
              （初期値は、すべて「参加」になっています）
            </p>
            {attSaved && (
              <div class="ap-error-banner" style="background:#DCFCE7;color:#166534;">
                <i class="fa-solid fa-check-circle"></i>
                出欠の変更を、保存しました。
              </div>
            )}
            <form action="/api/attendance" method="POST" class="lk-att-form">
              <input type="hidden" name="id" value={entry.id} />
              <input type="hidden" name="email" value={entry.email} />

            <div class="lk-attendees">
              {attendees.map(a => {
                const slots = slotsByAttendee[a.id] || [];
                return (
                  <article class="lk-attendee">
                    <header class="lk-attendee__head">
                      <span class="ap-attendee__num">{a.position}</span>
                      <span class="lk-attendee__name">{a.name}</span>
                      {a.grade && <span class="lk-attendee__grade">{a.grade}</span>}
                    </header>
                    {slots.length === 0 ? (
                      <p class="lk-attendee__empty">参加プログラムの選択はありません</p>
                    ) : (
                      <ul class="lk-slots">
                        {slots.map(s => (
                          <li class={`lk-slot lk-slot--checkable ${s.attended === 0 ? 'lk-slot--absent' : ''}`}>
                            <label class="lk-slot__check">
                              <input type="checkbox" name={`att_${s.entry_slot_id}`} value="1" checked={s.attended !== 0} />
                              <span class="lk-slot__check-box"></span>
                            </label>
                            <span class={`lk-slot__day ${s.day === 'Day1' ? 'lk-slot__day--navy' : 'lk-slot__day--orange'}`}>{s.day === 'Day1' ? 'DAY 1' : 'DAY 2'}</span>
                            <span class="lk-slot__time">{s.time_start}〜{s.time_end}</span>
                            <span class="lk-slot__name">{s.program_name}</span>
                            <span class="lk-slot__venue"><i class="fa-solid fa-location-dot"></i> {s.venue}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </article>
                );
              })}
            </div>

              <div class="ap-submit" style="margin-top:18px;">
                <button type="submit" class="ap-submit__btn" style="font-size:0.95rem;padding:14px 36px;">
                  <i class="fa-solid fa-floppy-disk"></i> 出欠を保存する
                </button>
              </div>
            </form>
          </div>

          {/* 今日のチェックイン状況サマリ */}
          <div class="ap-step" style="margin-top:24px;">
            <h2 class="ap-step__title"><span class="ap-step__num">3</span> 当日 チェックイン</h2>

            <div class="lk-checkin-status">
              {hasDay1 && (
                <div class={`lk-checkin-day ${dayCheckins['Day1'] ? 'lk-checkin-day--done' : ''}`}>
                  <span class="lk-checkin-day__pill day-pill day-pill--navy">DAY 1</span>
                  <span class="lk-checkin-day__date">12月19日（土）</span>
                  <span class="lk-checkin-day__state">
                    {dayCheckins['Day1']
                      ? <><i class="fa-solid fa-circle-check"></i> チェックイン済</>
                      : <><i class="fa-regular fa-circle"></i> 未チェックイン</>}
                  </span>
                </div>
              )}
              {hasDay2 && (
                <div class={`lk-checkin-day ${dayCheckins['Day2'] ? 'lk-checkin-day--done' : ''}`}>
                  <span class="lk-checkin-day__pill day-pill day-pill--orange">DAY 2</span>
                  <span class="lk-checkin-day__date">12月20日（日）</span>
                  <span class="lk-checkin-day__state">
                    {dayCheckins['Day2']
                      ? <><i class="fa-solid fa-circle-check"></i> チェックイン済</>
                      : <><i class="fa-regular fa-circle"></i> 未チェックイン</>}
                  </span>
                </div>
              )}
            </div>

            {checkinDone && (
              <div class="ap-error-banner" style="background:#DCFCE7;color:#166534;margin-top:14px;">
                <i class="fa-solid fa-circle-check"></i>
                {todayDay ? `${todayDay === 'Day1' ? 'DAY 1 (12/19)' : 'DAY 2 (12/20)'} のチェックインが、完了しました。`
                          : 'チェックインが、完了しました。'}
              </div>
            )}
          </div>

          {(todayChecked || (checkinDone && todayDay)) ? (
            <div class="ap-thanks" style="margin-top:24px;">
              <i class="fa-solid fa-circle-check"></i>
              <h2>本日の、チェックインは、完了しています</h2>
              <p>{entry.applicant_name} 様<br>受付番号 <strong>#{entry.id}</strong></p>
              {todayDay && (
                <p style="margin-top:8px;">
                  <span class={`day-pill ${todayDay === 'Day1' ? 'day-pill--navy' : 'day-pill--orange'}`} style="font-size:0.95rem;padding:6px 18px;">
                    {todayDay === 'Day1' ? 'DAY 1 ／ 12月19日（土）' : 'DAY 2 ／ 12月20日（日）'} 受付済
                  </span>
                </p>
              )}
              <div class="ap-thanks__notes">
                <p>当日は、各プログラムへ、お進みください。<br>会場マップ・スケジュールは、受付スタッフが、ご案内いたします。</p>
              </div>
              {(hasDay1 && hasDay2 && !allDaysChecked) && (
                <p style="margin-top:16px;font-size:0.88rem;color:var(--fsn-orange-dark);font-weight:700;">
                  ※翌日（{!dayCheckins['Day1'] ? 'DAY 1' : 'DAY 2'}）にも、改めて、受付QRからチェックインを、お願いいたします。
                </p>
              )}
              <a href="/202612orisen/" class="ap-thanks__back">
                <i class="fa-solid fa-arrow-left"></i> 特設サイトに戻る
              </a>
            </div>
          ) : (
            <div class="ap-step" style="margin-top:24px;">
              <h2 class="ap-step__title"><span class="ap-step__num">4</span> {todayDay ? `${todayDay === 'Day1' ? 'DAY 1 (12/19)' : 'DAY 2 (12/20)'} 会場到着 → チェックイン` : '会場到着 → チェックイン'}</h2>
              <p class="ap-step__desc">
                ご来場後に、以下から、チェックインを、お進めください。<br>
                <strong>会場の受付QRコード</strong>を、お読み取りいただいたあと、ぱん食い競走の参加意思を、ご確認いただきます。
              </p>

              <button type="button" id="start-scan" class="ck-big-btn ck-big-btn--navy" style="width:100%;">
                <i class="fa-solid fa-camera"></i>
                <span data-camera-label>会場の受付QRを読み取る</span>
              </button>

              <div id="scanner" class="ck-scanner" hidden>
                <video id="video" playsinline muted></video>
                <canvas id="canvas" style="display:none;"></canvas>
                <div class="ck-scanner__overlay">
                  <div class="ck-scanner__frame"></div>
                  <p class="ck-scanner__hint">会場の受付QRを枠内に映してください</p>
                </div>
              </div>

              <div id="venue-status" class="ck-status" hidden></div>

              <!-- 会場QR検証成功後に表示 -->
              <div id="checkin-form-area" hidden>
                <h3 style="margin:24px 0 12px;font-size:1.05rem;color:var(--fsn-navy-deep);">
                  <i class="fa-solid fa-check" style="color:var(--fsn-orange);"></i>
                  会場到着を、確認しました
                </h3>
                <p style="font-size:0.9rem;color:var(--fsn-gray-700);margin:0 0 16px;line-height:1.7;">
                  ぱん食い競走への、参加意思を、ご確認ください。
                </p>

                <form class="qr-pan-form" action="/api/qr-panshoku" method="POST">
                  <input type="hidden" name="token" value={entry.qr_token} />
                  <input type="hidden" name="from" value="checkin" />
                  <input type="hidden" name="redirect_to" value={`/202612orisen/lookup/?id=${entry.id}&email=${encodeURIComponent(entry.email)}`} />

                  <h4 class="qr-pan-section__title">ぱん食い競走に、ご参加される方</h4>
                  <p class="qr-pan-section__desc">
                    お申込み時の、ご参加者から、ぱん食い競走に、ご参加される方を、お選びください。
                  </p>
                  <div class="qr-pan-attendees">
                    {attendees.map(a => (
                      <label class="qr-pan-card">
                        <input type="checkbox" name={`pan_${a.id}`} value="1" defaultChecked={!!a.panshoku_join} />
                        <span class="qr-pan-card__check"></span>
                        <span class="qr-pan-card__body">
                          <span class="qr-pan-card__name">
                            <span class="ap-attendee__num">{a.position}</span>
                            {a.name}
                          </span>
                          {a.grade && <span class="qr-pan-card__grade">{a.grade}</span>}
                        </span>
                      </label>
                    ))}
                  </div>

                  <h4 class="qr-pan-section__title" style="margin-top:24px;">ぱん食い競走に、参加される同行者の方</h4>
                  <p class="qr-pan-section__desc">
                    お申込みに記載のない、保護者・きょうだいの方など、当日その場で、ぱん食い競走に、ご参加される方を、ご入力ください。
                  </p>
                  <div class="qr-pan-extras" data-extras></div>
                  <button type="button" class="qr-pan-add-big" data-add-extra>
                    <i class="fa-solid fa-circle-plus"></i>
                    <span>同行者を追加する</span>
                  </button>

                  <div class="ap-consents" style="margin-top:18px;">
                    <label class="ap-consent">
                      <input type="checkbox" name="allergy_ok" value="1" required />
                      <span><strong>食物アレルギー</strong>について、確認いたしました。参加者本人およびご家族のアレルギー有無を確認し、安全な範囲でご参加いただくことに、同意します。（必須）</span>
                    </label>
                  </div>
                  <div class="ap-submit">
                    <button type="submit" class="ap-submit__btn">
                      <i class="fa-solid fa-check"></i> チェックインを完了する
                    </button>
                  </div>
                </form>
              </div>
            </div>
          )}

          <p style="text-align:center;margin-top:16px;font-size:0.82rem;color:var(--fsn-gray-500);">
            変更・キャンセルは、お申込みメールにご返信ください。
          </p>
          </>
        )}
      </form>
    </div>
  </section>

  {entry && !entry.checked_in_at && (
    <>
      <script src="https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.min.js"></script>
      <script is:inline define:vars={{ VENUE_CODE: 'fsn2026-12' }}>
        (function() {
          const startBtn = document.getElementById('start-scan');
          const scannerEl = document.getElementById('scanner');
          const video = document.getElementById('video');
          const canvas = document.getElementById('canvas');
          const ctx = canvas.getContext('2d', { willReadFrequently: true });
          const statusEl = document.getElementById('venue-status');
          const formArea = document.getElementById('checkin-form-area');
          const cameraLabel = startBtn.querySelector('[data-camera-label]');
          let stream = null;
          let scanning = false;

          function setStatus(msg, type) {
            statusEl.hidden = false;
            statusEl.textContent = msg;
            statusEl.className = 'ck-status ' + (type ? 'ck-status--' + type : '');
          }

          async function start() {
            try {
              stream = await navigator.mediaDevices.getUserMedia({
                video: { facingMode: 'environment' }, audio: false,
              });
              video.srcObject = stream;
              await video.play();
              scannerEl.hidden = false;
              scanning = true;
              cameraLabel.textContent = '読み取り中… 停止';
              setStatus('会場の受付QRを枠内に映してください', 'scanning');
              tick();
            } catch (e) {
              setStatus('カメラを起動できません: ' + e.message, 'error');
            }
          }
          function stop() {
            scanning = false;
            if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
            video.srcObject = null;
            scannerEl.hidden = true;
            cameraLabel.textContent = '会場の受付QRを読み取る';
          }
          startBtn.addEventListener('click', () => { if (scanning) stop(); else start(); });

          function tick() {
            if (!scanning) return;
            if (video.readyState === video.HAVE_ENOUGH_DATA) {
              canvas.width = video.videoWidth;
              canvas.height = video.videoHeight;
              ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
              const img = ctx.getImageData(0, 0, canvas.width, canvas.height);
              const code = jsQR(img.data, img.width, img.height, { inversionAttempts: 'dontInvert' });
              if (code && code.data) {
                const data = code.data;
                // 会場QR検証: URL内 venue=VENUE_CODE または 文字列に VENUE_CODE が含まれる
                if (data.includes(VENUE_CODE) || (data.match(/venue=([^&]+)/) || [])[1] === VENUE_CODE) {
                  scanning = false;
                  stop();
                  if (navigator.vibrate) navigator.vibrate(180);
                  setStatus('✓ 会場到着を確認しました', 'success');
                  formArea.hidden = false;
                  startBtn.hidden = true;
                  formArea.scrollIntoView({ behavior: 'smooth', block: 'start' });
                  return;
                } else {
                  setStatus('別のQRコードが読み取られました。会場の受付QRを、お読み取りください。', 'error');
                }
              }
            }
            requestAnimationFrame(tick);
          }

          // 同行者 動的追加
          const extrasEl = document.querySelector('[data-extras]');
          const addBtn = document.querySelector('[data-add-extra]');
          if (extrasEl && addBtn) {
            function addRow() {
              const div = document.createElement('div');
              div.className = 'qr-pan-extra';
              div.innerHTML =
                '<div class="qr-pan-extra__head">' +
                  '<span class="ap-attendee__num">+</span>' +
                  '<span class="ap-attendee__label">同行者</span>' +
                  '<button type="button" class="qr-pan-extra__del" aria-label="削除">' +
                    '<i class="fa-solid fa-xmark"></i>' +
                  '</button>' +
                '</div>' +
                '<div class="qr-pan-extra__grid">' +
                  '<div class="ap-field"><label class="ap-label">お名前 <span class="ap-required">必須</span></label>' +
                    '<input type="text" name="extra_name" required class="ap-input" placeholder="例：田中 太郎" /></div>' +
                  '<div class="ap-field"><label class="ap-label">生年月日 <span class="ap-required">必須</span></label>' +
                    '<input type="date" name="extra_birth" required class="ap-input" min="1920-01-01" max="2026-12-31" /></div>' +
                  '<div class="ap-field"><label class="ap-label">ご属性 <span class="ap-required">必須</span></label>' +
                    '<select name="extra_attr" required class="ap-input">' +
                      '<option value="">選択してください</option>' +
                      '<option value="保護者">保護者</option>' +
                      '<option value="子ども">子ども</option>' +
                      '<option value="一般">一般</option>' +
                      '<option value="指導者">指導者</option>' +
                      '<option value="運営団体">運営団体</option>' +
                    '</select></div>' +
                '</div>';
              extrasEl.appendChild(div);
              div.querySelector('.qr-pan-extra__del').addEventListener('click', () => div.remove());
            }
            addBtn.addEventListener('click', addRow);
          }
        })();
      </script>
    </>
  )}

</BaseLayout>
