---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/202612orisen.css';

// 画像は /public/programs/{code}.jpg （16:9）に配置想定。画像が無い間は グラデ背景でプレースホルダー
// day: '12/19' | '12/20' | '12/19-20' の3値。バッジのカラーも 3パターンで色分け（CSS の data-day 属性で切替）
const programs = [
  { code: 'panshoku',      name: 'スポあんぱん食い競走',    time: '11:00 ／ 13:00',        venue: '中央広場',             day: '12/19-20', theme: 'orange', featured: true },
  { code: 'kakekko',       name: 'かけっこ教室',             time: '12:00 ／ 14:00',        venue: '中央広場',             day: '12/19-20', theme: 'green' },
  { code: 'music-dribble', name: 'ミュージックドリブル',    time: '10:00 - 12:00',         venue: '第1体育室',            day: '12/19',    theme: 'navy' },
  { code: 'soccer',        name: 'サッカー教室',              time: '13:00 - 14:00',         venue: '第1体育室',            day: '12/19',    theme: 'navy' },
  { code: 'baseball5',     name: 'Baseball5 体験',           time: '10:00 - 14:00 通し',    venue: '第1体育室',            day: '12/20',    theme: 'navy' },
  { code: 'legit',         name: 'Legit ダンス',              time: '11:00 ／ 13:00 ／ 15:00', venue: '第1・4体育室',      day: '12/20',    theme: 'pink' },
  { code: 'sunrockers',    name: 'サンロッカーズ渋谷 バスケ', time: '10:00 - 14:00 通し',   venue: '第3体育室',            day: '12/19',    theme: 'orange' },
  { code: '3x3',           name: '3x3 バスケ',                time: '10:00 ／ 13:00',        venue: '第3体育室',            day: '12/20',    theme: 'orange' },
  { code: 'dip',           name: 'Dip Battles',                time: '10:00 ／ 12:00',        venue: '第4体育室',            day: '12/19',    theme: 'purple' },
  { code: 'judo',          name: '柔道体験',                   time: '10:00 ／ 12:00 ／ 14:00', venue: '第5体育室',         day: '12/19',    theme: 'green' },
  { code: 'fencing',       name: 'フェンシング体験',           time: '10:00 ／ 12:00 ／ 14:00', venue: '第5体育室',         day: '12/20',    theme: 'orange' },
  { code: 'ycap',          name: 'YCAP チームビルディング',    time: '10:00 ／ 12:00 ／ 14:00', venue: 'YCAPエリア',         day: '12/19',    theme: 'purple' },
  { code: 'parkour',       name: 'パルクール',                  time: '10:00 ／ 12:00 ／ 14:00', venue: 'YCAPエリア',         day: '12/20',    theme: 'purple' },
  { code: 'rec-bousai',    name: 'レク協会 ／ 防災スポーツ',   time: '11:00 - 14:00 通し',    venue: '第2体育室',            day: '12/19-20', theme: 'yellow' },
  { code: 'boccia',        name: 'ボッチャ',                    time: '自由参加 ／ 終日通し',  venue: '体育室エントランス',   day: '12/19-20', theme: 'blue' },
  { code: 'shogi',         name: '将棋 ／ カードゲーム',        time: '自由参加 ／ 終日通し',  venue: '体育室エントランス',   day: '12/19-20', theme: 'blue' },
  { code: 'esports',       name: 'eスポーツ ／ 雀魂',            time: '自由参加 ／ 終日通し',  venue: '体育室エントランス',   day: '12/19',    theme: 'blue' },
  { code: 'radio',         name: '渋谷のラジオ 公開収録',       time: '通し',                  venue: '体育室エントランス',   day: '12/19-20', theme: 'pink' },
];
---
<BaseLayout
  title="fun sport nexus 2026.12"
  description="2026年12月19日（土）・20日（日）開催。国立オリンピック記念青少年総合センターで、明るく、楽しく、人と人をつなぐ2日間。"
>

  <!-- Hero -->
  <section class="dec-hero">
    <div class="dec-hero__bg" style="background-image: url('/hero-bg.jpg');"></div>
    <div class="dec-hero__overlay"></div>
    <div class="dec-hero__inner">
      <p class="dec-hero__label">FUN SPORT NEXUS  ／  2026 WINTER</p>
      <h1 class="dec-hero__catch">明るく、楽しく、<br>人と人をつなぐ。</h1>
      <p class="dec-hero__lead">
        12月19日と20日の2日間、国立オリンピック記念青少年総合センターで、<br>
        「fun sport nexus」を、ひらきます。
      </p>
      <div class="dec-hero__meta">
        <span class="dec-hero__meta-item"><i class="fa-solid fa-calendar-days"></i> 2026.12.19（土） - 20（日）</span>
        <span class="dec-hero__meta-item"><i class="fa-solid fa-location-dot"></i> 国立オリンピック記念青少年総合センター</span>
        <span class="dec-hero__meta-item dec-hero__meta-item--free"><i class="fa-solid fa-ticket"></i> 参加費無料</span>
      </div>
      <p style="margin: 24px 0 0;">
        <a href="/202612orisen/apply/" class="dec-btn dec-btn--primary dec-btn--lg">
          <i class="fa-solid fa-pen-to-square"></i>
          参加を申し込む
        </a>
      </p>
    </div>
  </section>

  <!-- HIGHLIGHT PROGRAMS -->
  <section class="dec-section">
    <div class="dec-section__inner">
      <p class="dec-section__label dec-section__label--orange">PROGRAMS</p>
      <h2 class="dec-section__title">2日間で楽しめる、<br>多彩なプログラム</h2>
      <p class="dec-section__lead">
        マルチスポーツ ／ マルチカルチャー。<br>
        ぱん食い競走、Baseball5、3x3、Legit、フェンシング、パルクール、Dip Battles など、<br>
        {programs.length}のプログラムを、無料で体験できます。
      </p>

      <div class="dec-stats">
        <div class="dec-stat">
          <span class="dec-stat__num">{programs.length}<span class="dec-stat__plus">+</span></span>
          <span class="dec-stat__label">プログラム</span>
        </div>
        <div class="dec-stat">
          <span class="dec-stat__num">2</span>
          <span class="dec-stat__label">日間 開催</span>
        </div>
        <div class="dec-stat">
          <span class="dec-stat__num dec-stat__num--text">無料</span>
          <span class="dec-stat__label">参加費</span>
        </div>
      </div>

      <div class="dec-progmini__grid">
        {programs.map(p => (
          <a href="/202612orisen/programs/" class={`dec-progmini dec-progmini--theme-${p.theme || 'navy'} ${p.featured ? 'dec-progmini--featured' : ''} ${p.special ? 'dec-progmini--special' : ''}`}>
            <span class="dec-progmini__image">
              <img src={`/programs/${p.code}.jpg`} alt="" loading="lazy" decoding="async" onerror="this.style.display='none'" />
              <span class="dec-progmini__day-badge" data-day={p.day}>{p.day}</span>
            </span>
            <span class="dec-progmini__body">
              <span class="dec-progmini__name">{p.name}</span>
              <span class="dec-progmini__meta">
                <span class="dec-progmini__time"><i class="fa-regular fa-clock"></i> {p.time}</span>
                <span class="dec-progmini__venue"><i class="fa-solid fa-location-dot"></i> {p.venue}</span>
              </span>
            </span>
          </a>
        ))}
      </div>

      <p style="text-align: center; margin-top: 32px;">
        <a href="/202612orisen/programs/" class="dec-link">
          プログラム詳細を見る
          <i class="fa-solid fa-arrow-right"></i>
        </a>
      </p>
    </div>
  </section>

  <!-- TIMETABLE 会場別グルーピング -->
  <section class="dec-section dec-section--tint">
    <div class="dec-section__inner">
      <p class="dec-section__label">TIMETABLE</p>
      <h2 class="dec-section__title">プログラム スケジュール</h2>
      <p class="dec-section__lead">
        会場ごとに、開催プログラムと、時間を、ご紹介します。<br>
        ※現時点の仮入れ。最終確定は、各団体との調整後に、ご案内いたします。
      </p>

      <!-- Day1 タイムテーブル -->
      <div class="dec-tt-block">
        <div class="dec-tt-block__head dec-tt-block__head--navy">
          <span class="dec-tt-block__num">DAY 1</span>
          <span class="dec-tt-block__date">12月19日（土）</span>
          <span style="margin-left: auto; font-size: 0.95rem; font-weight: 600; opacity: 0.92;">体験会 ／ マルチスポ・カル</span>
        </div>
        <div class="dec-tt-wrap">
          <table class="dec-tt dec-tt--v2">
            <thead>
              <tr>
                <th class="dec-tt__venue">会場</th>
                <th>10:00</th><th>11:00</th><th>12:00</th><th>13:00</th><th>14:00</th><th>15:00</th>
              </tr>
            </thead>
            <tbody>
              <tr><th><i class="fa-solid fa-location-dot"></i> 中央広場</th>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--orange">ぱん食い<small>11:00</small></td>
                <td class="dec-tt__bar dec-tt__bar--green">かけっこ<small>12:00</small></td>
                <td class="dec-tt__bar dec-tt__bar--orange">ぱん食い<small>13:00</small></td>
                <td class="dec-tt__bar dec-tt__bar--green">かけっこ<small>14:00</small></td>
                <td class="dec-tt__empty"></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> 第1体育室</th>
                <td colspan="2" class="dec-tt__bar dec-tt__bar--navy">ミュージックドリブル<small>10:00 - 12:00</small></td>
                <td class="dec-tt__empty"></td>
                <td colspan="2" class="dec-tt__bar dec-tt__bar--navy">サッカー教室<small>13:00 - 14:00</small></td>
                <td class="dec-tt__bar dec-tt__bar--purple">Dip<small>15:00</small></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> 第2体育室</th>
                <td class="dec-tt__empty"></td>
                <td colspan="4" class="dec-tt__bar dec-tt__bar--yellow">レク協会 ／ 防災スポーツ<small>11:00 - 14:00 通し</small></td>
                <td class="dec-tt__empty"></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> 第3体育室</th>
                <td class="dec-tt__empty"></td>
                <td colspan="4" class="dec-tt__bar dec-tt__bar--orange">サンロッカーズ渋谷 バスケ<small>11:00 - 14:00 通し</small></td>
                <td class="dec-tt__empty"></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> 第4体育室</th>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--purple">Dip ①<small>11:00</small></td>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--purple">Dip ②<small>13:00</small></td>
                <td colspan="2" class="dec-tt__empty"></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> 第5体育室</th>
                <td class="dec-tt__bar dec-tt__bar--green">柔道 ①<small>10:00</small></td>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--green">柔道 ②<small>12:00</small></td>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--green">柔道 ③<small>14:00</small></td>
                <td class="dec-tt__empty"></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> YCAPエリア</th>
                <td class="dec-tt__bar dec-tt__bar--purple">YCAP ①<small>10:00</small></td>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--purple">YCAP ②<small>12:00</small></td>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--purple">YCAP ③<small>14:00</small></td>
                <td class="dec-tt__empty"></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> 体育室エントランス</th>
                <td colspan="6" class="dec-tt__bar dec-tt__bar--blue">ボッチャ・将棋・カードゲーム・雀魂・渋谷のラジオ<small>10:00 - 15:00 通し</small></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="dec-tt__special">
          <i class="fa-solid fa-microphone-lines"></i>
          <span><strong>16:30 - 18:30</strong> トーク ＋ ワークショップ（120分）<small>センター棟 ／ 「スポーツと遊び」トークセッション ＋ ワークショップ ＋ 助成金採択団体 ポスターセッション</small></span>
        </div>
      </div>

      <!-- Day2 タイムテーブル -->
      <div class="dec-tt-block">
        <div class="dec-tt-block__head dec-tt-block__head--orange">
          <span class="dec-tt-block__num">DAY 2</span>
          <span class="dec-tt-block__date">12月20日（日）</span>
          <span style="margin-left: auto; font-size: 0.95rem; font-weight: 600; opacity: 0.92;">体験会 ＋ 大会要素</span>
        </div>
        <div class="dec-tt-wrap">
          <table class="dec-tt dec-tt--v2">
            <thead>
              <tr>
                <th class="dec-tt__venue">会場</th>
                <th>10:00</th><th>11:00</th><th>12:00</th><th>13:00</th><th>14:00</th><th>15:00</th>
              </tr>
            </thead>
            <tbody>
              <tr><th><i class="fa-solid fa-location-dot"></i> 中央広場</th>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--orange">ぱん食い<small>11:00</small></td>
                <td class="dec-tt__bar dec-tt__bar--green">かけっこ<small>12:00</small></td>
                <td class="dec-tt__bar dec-tt__bar--orange">ぱん食い<small>13:00</small></td>
                <td class="dec-tt__bar dec-tt__bar--green">かけっこ<small>14:00</small></td>
                <td class="dec-tt__empty"></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> 第1体育室</th>
                <td colspan="5" class="dec-tt__bar dec-tt__bar--navy">Baseball5<small>10:00 - 14:00 通し</small></td>
                <td class="dec-tt__bar dec-tt__bar--pink">Legit<small>15:00</small></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> 第2体育室</th>
                <td class="dec-tt__empty"></td>
                <td colspan="4" class="dec-tt__bar dec-tt__bar--yellow">レク協会 ／ 防災スポーツ<small>11:00 - 14:00 通し</small></td>
                <td class="dec-tt__empty"></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> 第3体育室</th>
                <td colspan="2" class="dec-tt__bar dec-tt__bar--orange">3x3 バスケ ①<small>10:00 - 11:00</small></td>
                <td class="dec-tt__empty"></td>
                <td colspan="2" class="dec-tt__bar dec-tt__bar--orange">3x3 バスケ ②<small>13:00 - 14:00</small></td>
                <td class="dec-tt__empty"></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> 第4体育室</th>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--pink">Legit ①<small>11:00</small></td>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--pink">Legit ②<small>13:00</small></td>
                <td colspan="2" class="dec-tt__empty"></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> 第5体育室</th>
                <td class="dec-tt__bar dec-tt__bar--orange">フェンシング ①<small>10:00</small></td>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--orange">フェンシング ②<small>12:00</small></td>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--orange">フェンシング ③<small>14:00</small></td>
                <td class="dec-tt__empty"></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> YCAPエリア</th>
                <td class="dec-tt__bar dec-tt__bar--purple">パルクール ①<small>10:00</small></td>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--purple">パルクール ②<small>12:00</small></td>
                <td class="dec-tt__empty"></td>
                <td class="dec-tt__bar dec-tt__bar--purple">パルクール ③<small>14:00</small></td>
                <td class="dec-tt__empty"></td>
              </tr>
              <tr><th><i class="fa-solid fa-location-dot"></i> 体育室エントランス</th>
                <td colspan="6" class="dec-tt__bar dec-tt__bar--blue">ボッチャ・将棋・カードゲーム・渋谷のラジオ<small>10:00 - 15:00 通し</small></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <p style="text-align: center; font-size: 0.82rem; color: var(--fsn-gray-500); margin: 16px 0 0;">
        ※スマートフォンの方は、表を横にスクロールして、ご覧ください。
      </p>
    </div>
  </section>

  <!-- SPECIAL SEMINAR -->
  <section class="dec-section">
    <div class="dec-section__inner">
      <p class="dec-section__label dec-section__label--orange">SPECIAL SEMINAR</p>
      <h2 class="dec-section__title">トークセッション ＋ ワークショップ</h2>
      <p class="dec-section__lead">
        Day1の夕方、「スポーツと遊び」をテーマに、教育・スポーツの第一線で活躍する方々を、お招きします。<br>
        トークセッションと、参加型ワークショップを、おこないます。
      </p>

      <div class="dec-seminar__info">
        <div class="dec-seminar__info-item">
          <span class="dec-seminar__info-label">日時</span>
          <span class="dec-seminar__info-value">12月19日（土）16:30 - 18:30（120分）</span>
        </div>
        <div class="dec-seminar__info-item">
          <span class="dec-seminar__info-label">会場</span>
          <span class="dec-seminar__info-value">オリセン センター棟 内</span>
        </div>
        <div class="dec-seminar__info-item">
          <span class="dec-seminar__info-label">構成</span>
          <span class="dec-seminar__info-value">トークセッション ＋ ワークショップ ＋ 交流会</span>
        </div>
      </div>

      <h3 class="dec-seminar__sub">トークセッション「スポーツと遊び」<small style="font-weight: 500; margin-left: 12px; opacity: 0.8;">16:30 - 17:30 ／ 60分</small></h3>
      <div class="dec-seminar__grid">
        <article class="dec-seminar-card">
          <div class="dec-seminar-card__photo" style="background-image: url('/logo-fsn.png');"></div>
          <div class="dec-seminar-card__body">
            <p class="dec-seminar-card__name">田丸 尚稔</p>
            <p class="dec-seminar-card__title">一般財団法人 渋谷区スポーツ協会  専務理事</p>
          </div>
        </article>
        <article class="dec-seminar-card">
          <div class="dec-seminar-card__photo" style="background-image: url('/logo-fsn.png');"></div>
          <div class="dec-seminar-card__body">
            <p class="dec-seminar-card__name">吉武 裕平</p>
            <p class="dec-seminar-card__title">「ポジティブコーチング」×「ユーススポーツリーグ」推進実行委員会  委員長</p>
          </div>
        </article>
        <article class="dec-seminar-card">
          <div class="dec-seminar-card__photo" style="background-image: url('/logo-fsn.png');"></div>
          <div class="dec-seminar-card__body">
            <p class="dec-seminar-card__name">寺田 拓真</p>
            <p class="dec-seminar-card__title">広島県 総務局付課長 ／ 福山市 教育委員会 学校教育部 参与 ／ 大阪教育大学 客員教授</p>
          </div>
        </article>
      </div>

      <h3 class="dec-seminar__sub" style="margin-top: 40px;">ワークショップ<small style="font-weight: 500; margin-left: 12px; opacity: 0.8;">17:30 - 18:30 ／ 60分</small></h3>
      <div class="dec-seminar__info" style="margin-top: 16px;">
        <div class="dec-seminar__info-item">
          <span class="dec-seminar__info-label">形式</span>
          <span class="dec-seminar__info-value">8人ぐらいの少人数ワークショップ</span>
        </div>
        <div class="dec-seminar__info-item">
          <span class="dec-seminar__info-label">テーマ（案）</span>
          <span class="dec-seminar__info-value">①「遊び」から生まれたスポーツ ／ ②子どもの「自主性」を高める</span>
        </div>
      </div>

      <h3 class="dec-seminar__sub" style="margin-top: 40px;">ポスターセッション <small style="font-weight: 500; margin-left: 12px; opacity: 0.8;">助成金採択団体の事例紹介</small></h3>
      <div class="dec-seminar__info" style="margin-top: 16px;">
        <div class="dec-seminar__info-item">
          <span class="dec-seminar__info-label">会場</span>
          <span class="dec-seminar__info-value">カルチャー棟 小ホール 展示コーナー</span>
        </div>
        <div class="dec-seminar__info-item">
          <span class="dec-seminar__info-label">内容</span>
          <span class="dec-seminar__info-value">fun sport nexus と同じベクトルで活動する団体の紹介と、意見交換の場</span>
        </div>
      </div>

