---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/202612orisen.css';
import '../../../styles/apply-form.css';

export const prerender = false;

const env = Astro.locals?.runtime?.env ?? {};
const token = Astro.url.searchParams.get('t') || '';
const done = Astro.url.searchParams.get('done') === '1';
const qrError = Astro.url.searchParams.get('error') || '';
const isCheckinMode = Astro.url.searchParams.get('from') === 'checkin';

let entry = null;
let attendees = [];
let entrySlots = [];
let lookupError = null;

if (token && env.DB) {
  try {
    const e = await env.DB.prepare('SELECT * FROM entries WHERE qr_token = ?').bind(token).first();
    if (e) {
      entry = e;
      const a = await env.DB.prepare(`
        SELECT * FROM entry_attendees WHERE entry_id = ? ORDER BY position
      `).bind(e.id).all();
      attendees = a?.results ?? [];
      const s = await env.DB.prepare(`
        SELECT es.attendee_id, s.id AS slot_id, s.program_name, s.day, s.time_start, s.time_end, s.venue
        FROM entry_slots es
        INNER JOIN slots s ON es.slot_id = s.id
        WHERE es.entry_id = ?
        ORDER BY s.day, s.time_start
      `).bind(e.id).all();
      entrySlots = s?.results ?? [];
    }
  } catch (e) {
    lookupError = e.message;
  }
}

const slotsByAttendee = {};
for (const s of entrySlots) {
  const k = s.attendee_id || 0;
  if (!slotsByAttendee[k]) slotsByAttendee[k] = [];
  slotsByAttendee[k].push(s);
}
---
<BaseLayout
  title="当日受付 ｜ fun sport nexus 2026.12"
  description="QRコードから 当日受付内容を、ご確認いただけます。"
  noindex={true}
>

  <section class="dec-sub-hero">
    <div class="dec-sub-hero__bg"></div>
    <div class="dec-sub-hero__inner">
      <p class="dec-sub-hero__label">CHECK-IN</p>
      <h1 class="dec-sub-hero__title">当日受付</h1>
    </div>
  </section>

  <section class="ap-section">
    <div class="ap-section__inner" style="max-width: 760px;">
      {!token ? (
        <div class="ap-error-banner"><i class="fa-solid fa-circle-exclamation"></i> トークンが指定されていません。お申込み完了メールのQRコードから、お進みください。</div>
      ) : !entry ? (
        <div class="ap-error-banner"><i class="fa-solid fa-circle-exclamation"></i> 該当のお申込みが、見つかりませんでした。{lookupError && `（${lookupError}）`}</div>
      ) : done ? (
        <div class="ap-thanks">
          <i class="fa-solid fa-circle-check"></i>
          <h2>チェックイン完了</h2>
          <p>
            {entry.applicant_name} 様<br>
            受付番号 <strong>#{entry.id}</strong> の<br>
            チェックインが、完了いたしました。
          </p>
          <div class="ap-thanks__notes">
            <p>当日は、各プログラムへ、お進みください。<br>会場マップ・スケジュールは、受付スタッフが、ご案内いたします。</p>
          </div>
          <a href="/202612orisen/" class="ap-thanks__back">
            <i class="fa-solid fa-arrow-left"></i> 特設サイトに戻る
          </a>
        </div>
      ) : (
        <div class="qr-confirm">
          {qrError && (
            <div class="ap-error-banner">
              <i class="fa-solid fa-circle-exclamation"></i>
              {qrError === 'no_allergy' ? '食物アレルギーの確認に、チェックを、お願いいたします。' :
               qrError === 'invalid_token' ? '受付情報が見つかりません。再度、QRから、お進みください。' :
               qrError === 'server' ? 'システム障害が発生しました。スタッフにお声がけください。' :
               qrError === 'need_venue' ? 'チェックインは、会場の受付QRから、お進みください。' :
               'エラーが発生しました：' + qrError}
            </div>
          )}
          <div class="ap-step">
            <h2 class="ap-step__title"><span class="ap-step__num">1</span> お申込み者（代表者）情報</h2>
            <dl class="lk-meta">
              <div><dt>受付番号</dt><dd><strong>#{entry.id}</strong></dd></div>
              <div><dt>お名前</dt><dd>{entry.applicant_name} 様（{entry.applicant_furigana}）</dd></div>
              <div><dt>メール</dt><dd>{entry.email}</dd></div>
              <div><dt>お電話</dt><dd>{entry.tel}</dd></div>
            </dl>
          </div>

          <div class="ap-step">
            <h2 class="ap-step__title"><span class="ap-step__num">2</span> ご参加者（{entry.attendees}名）</h2>

            <div class="lk-attendees">
              {attendees.map(a => {
                const slots = slotsByAttendee[a.id] || [];
                return (
                  <article class="lk-attendee">
                    <header class="lk-attendee__head">
                      <span class="ap-attendee__num">{a.position}</span>
                      <span class="lk-attendee__name">{a.name}</span>
                      {a.grade && <span class="lk-attendee__grade">{a.grade}</span>}
                    </header>
                    {slots.length === 0 ? (
                      <p class="lk-attendee__empty">参加プログラムの選択はありません</p>
                    ) : (
                      <ul class="lk-slots">
                        {slots.map(s => (
                          <li class="lk-slot">
                            <span class={`lk-slot__day ${s.day === 'Day1' ? 'lk-slot__day--navy' : 'lk-slot__day--orange'}`}>{s.day === 'Day1' ? 'DAY 1' : 'DAY 2'}</span>
                            <span class="lk-slot__time">{s.time_start}〜{s.time_end}</span>
                            <span class="lk-slot__name">{s.program_name}</span>
                            <span class="lk-slot__venue"><i class="fa-solid fa-location-dot"></i> {s.venue}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </article>
                );
              })}
            </div>
          </div>

          {!isCheckinMode && (
            <div class="ap-error-banner" style="background:#FEF3C7;color:#92400E;">
              <i class="fa-solid fa-info-circle"></i>
              <div>
                <strong style="display:block;margin-bottom:4px;">ご来場後に、チェックインを、お願いいたします</strong>
                チェックインは、会場の<strong>受付QRコード</strong>を、お読み取りいただいた後の画面から、お進みください。<br>
                このページでは、お申し込み内容のご確認のみ、可能です。
              </div>
            </div>
          )}

          {isCheckinMode && (
          <div class="ap-step">
            <h2 class="ap-step__title"><span class="ap-step__num">3</span> ぱん食い競走への参加について</h2>
            <p class="ap-step__desc">
              「スポあんぱん食い競走」は、当日 自由参加でお楽しみいただけます。<br>
              参加されるご予定の方は、以下から、お申し込みください。<br>
              ※パンには、小麦・卵・乳成分等のアレルギー物質が含まれます。
            </p>

            <form class="qr-pan-form" action="/api/qr-panshoku" method="POST">
              <input type="hidden" name="token" value={token} />
              <input type="hidden" name="from" value="checkin" />

              <h3 class="qr-pan-section__title">お申込み時の、ご参加者</h3>
              <div class="qr-pan-attendees">
                {attendees.map(a => (
                  <label class="qr-pan-card">
                    <input type="checkbox" name={`pan_${a.id}`} value="1" defaultChecked={!!a.panshoku_join} />
                    <span class="qr-pan-card__check"></span>
                    <span class="qr-pan-card__body">
                      <span class="qr-pan-card__name">
                        <span class="ap-attendee__num">{a.position}</span>
                        {a.name}
                      </span>
                      {a.grade && <span class="qr-pan-card__grade">{a.grade}</span>}
                    </span>
                  </label>
                ))}
              </div>

              <h3 class="qr-pan-section__title" style="margin-top:24px;">当日 同行される方（任意）</h3>
              <p class="qr-pan-section__desc">
                保護者・お子さま・ご一緒の方など、ぱん食い競走に、ご参加される方を、お一人ずつ、ご入力ください。
              </p>
              <div class="qr-pan-extras" data-extras></div>
              <button type="button" class="qr-pan-add" data-add-extra>
                <i class="fa-solid fa-plus"></i> 当日同行者を追加
              </button>

              <div class="ap-consents" style="margin-top:24px;">
                <label class="ap-consent">
                  <input type="checkbox" name="allergy_ok" value="1" required defaultChecked={!!attendees.find(a => a.panshoku_allergy_ok)} />
                  <span><strong>食物アレルギー</strong>について、確認いたしました。参加者本人およびご家族のアレルギー有無を確認し、安全な範囲でご参加いただくことに、同意します。（必須）</span>
                </label>
              </div>
              <div class="ap-submit">
                <button type="submit" class="ap-submit__btn">
                  <i class="fa-solid fa-check"></i> ぱん食い競走の参加を、確定する
                </button>
              </div>
            </form>

            <script is:inline>
              (function() {
                const extrasEl = document.querySelector('[data-extras]');
                const addBtn = document.querySelector('[data-add-extra]');
                if (!extrasEl || !addBtn) return;

                function addRow() {
                  const div = document.createElement('div');
                  div.className = 'qr-pan-extra';
                  div.innerHTML =
                    '<div class="qr-pan-extra__head">' +
                      '<span class="ap-attendee__num">+</span>' +
                      '<span class="ap-attendee__label">同行者</span>' +
                      '<button type="button" class="qr-pan-extra__del" aria-label="削除">' +
                        '<i class="fa-solid fa-xmark"></i>' +
                      '</button>' +
                    '</div>' +
                    '<div class="qr-pan-extra__grid">' +
                      '<div class="ap-field">' +
                        '<label class="ap-label">お名前 <span class="ap-required">必須</span></label>' +
                        '<input type="text" name="extra_name" required class="ap-input" placeholder="例：田中 太郎" />' +
                      '</div>' +
                      '<div class="ap-field">' +
                        '<label class="ap-label">生年月日 <span class="ap-required">必須</span></label>' +
                        '<input type="date" name="extra_birth" required class="ap-input" min="1920-01-01" max="2026-12-31" />' +
                      '</div>' +
                      '<div class="ap-field">' +
                        '<label class="ap-label">ご属性 <span class="ap-required">必須</span></label>' +
                        '<select name="extra_attr" required class="ap-input">' +
                          '<option value="">選択してください</option>' +
                          '<option value="保護者">保護者</option>' +
                          '<option value="子ども">子ども</option>' +
                          '<option value="一般">一般</option>' +
                          '<option value="指導者">指導者</option>' +
                          '<option value="運営団体">運営団体</option>' +
                        '</select>' +
                      '</div>' +
                    '</div>';
                  extrasEl.appendChild(div);
                  div.querySelector('.qr-pan-extra__del').addEventListener('click', () => div.remove());
                }
                addBtn.addEventListener('click', addRow);
              })();
            </script>
          </div>
          )}
        </div>
      )}
    </div>
  </section>

</BaseLayout>

<style is:global>
  .qr-meta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 8px 16px;
    margin: 16px 0 24px;
    font-size: 0.92rem;
  }
  .qr-meta > div { display: contents; }
  .qr-meta dt { font-weight: 800; color: var(--fsn-orange-dark); font-size: 0.82rem; }
  .qr-meta dd { margin: 0; color: var(--fsn-navy-deep); }

  .qr-attendees { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .qr-attendee {
    background: var(--fsn-gray-50);
    border-radius: var(--fsn-radius-sm);
    padding: 14px 16px;
  }
  .qr-attendee__head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 10px;
    flex-wrap: wrap;
  }
  .qr-attendee__name { font-weight: 800; color: var(--fsn-navy-deep); font-size: 1.05rem; }
  .qr-attendee__grade { font-size: 0.82rem; color: var(--fsn-orange-dark); font-weight: 700; }
  .qr-slots { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .qr-slots li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    flex-wrap: wrap;
  }
  .qr-slots li strong { color: var(--fsn-navy-deep); }
  .qr-slot__venue { font-size: 0.78rem; color: var(--fsn-gray-700); }
  .qr-slot__venue i { color: var(--fsn-orange); }

  .qr-pan-section__title {
    font-size: 1rem;
    font-weight: 800;
    color: var(--fsn-navy-deep);
    margin: 0 0 8px;
  }
  .qr-pan-section__desc {
    font-size: 0.85rem;
    color: var(--fsn-gray-700);
    margin: 0 0 12px;
    line-height: 1.7;
  }

  .qr-pan-attendees { display: flex; flex-direction: column; gap: 10px; }
  .qr-pan-card {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    background: var(--fsn-white);
    border: 1.5px solid var(--fsn-gray-200);
    border-radius: var(--fsn-radius-sm);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .qr-pan-card:has(input:checked) {
    border-color: var(--fsn-orange);
    background: #FFF7ED;
  }
  .qr-pan-card input[type="checkbox"] {
    position: absolute; opacity: 0; width: 0; height: 0;
  }
  .qr-pan-card__check {
    width: 26px;
    height: 26px;
    border: 2px solid var(--fsn-gray-300);
    border-radius: 6px;
    background: var(--fsn-white);
    position: relative;
    transition: background 0.15s, border-color 0.15s;
  }
  .qr-pan-card:has(input:checked) .qr-pan-card__check {
    background: var(--fsn-orange);
    border-color: var(--fsn-orange);
  }
  .qr-pan-card:has(input:checked) .qr-pan-card__check::after {
    content: "✓";
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--fsn-white);
    font-weight: 900;
    font-size: 1rem;
  }
  .qr-pan-card__body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .qr-pan-card__name {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1rem;
    font-weight: 800;
    color: var(--fsn-navy-deep);
  }
  .qr-pan-card__grade {
    font-size: 0.78rem;
    color: var(--fsn-orange-dark);
    font-weight: 700;
  }

  /* 追加同行者 */
  .qr-pan-extras { display: flex; flex-direction: column; gap: 12px; margin-bottom: 12px; }
  .qr-pan-extra {
    background: var(--fsn-gray-50);
    border: 1px dashed var(--fsn-orange);
    border-radius: var(--fsn-radius-sm);
    padding: 14px 16px;
  }
  .qr-pan-extra__head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .qr-pan-extra__del {
    margin-left: auto;
    background: transparent;
    border: 0;
    color: var(--fsn-gray-500);
    cursor: pointer;
    font-size: 1rem;
    padding: 4px 10px;
    border-radius: var(--fsn-radius-sm);
    transition: background 0.15s, color 0.15s;
  }
  .qr-pan-extra__del:hover {
    background: #FEE2E2;
    color: #DC2626;
  }
  .qr-pan-extra__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 10px;
  }
  @media (max-width: 760px) {
    .qr-pan-extra__grid { grid-template-columns: 1fr; }
  }

  .qr-pan-add {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: var(--fsn-white);
    color: var(--fsn-orange-dark);
    border: 2px dashed var(--fsn-orange);
    border-radius: var(--fsn-radius-sm);
    font-size: 0.92rem;
    font-weight: 700;
    cursor: pointer;
  }
  .qr-pan-add:hover { background: #FFF7ED; }
</style>
