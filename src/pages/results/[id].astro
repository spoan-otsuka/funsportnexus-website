---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MicrocmsImage from '../../components/MicrocmsImage.astro';
import { fetchResultDetail } from '../../lib/microcms';

export const prerender = false;

const { id } = Astro.params;

let article = null;
let fetchError = null;

try {
  article = await fetchResultDetail(Astro.locals, id);
} catch (err) {
  console.error('Failed to fetch result detail:', err);
  fetchError = err.message;
}

if (!article && !fetchError) {
  return Astro.redirect('/results/');
}

const formatDate = (iso) => {
  if (!iso) return '';
  const d = new Date(iso);
  return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
};

const formatDateRange = (startIso, endIso) => {
  if (!startIso) return '';
  if (!endIso) return formatDate(startIso);
  const s = new Date(startIso);
  const e = new Date(endIso);
  const sy = s.getFullYear(), sm = s.getMonth() + 1, sd = s.getDate();
  const ey = e.getFullYear(), em = e.getMonth() + 1, ed = e.getDate();
  if (sy === ey && sm === em && sd === ed) return formatDate(startIso);
  const pad = (n) => String(n).padStart(2, '0');
  if (sy === ey && sm === em) {
    return `${sy}.${pad(sm)}.${pad(sd)} - ${pad(ed)}`;
  }
  if (sy === ey) {
    return `${sy}.${pad(sm)}.${pad(sd)} - ${pad(em)}.${pad(ed)}`;
  }
  return `${sy}.${pad(sm)}.${pad(sd)} - ${ey}.${pad(em)}.${pad(ed)}`;
};

const eyecatchUrl = article?.eyecatch?.url ?? null;
const eyecatchMobileUrl = article?.eyecatchMobile?.url ?? null;
const ogImageUrl = eyecatchUrl ? `${eyecatchUrl}?w=1200&h=630&fit=crop` : '/og-default.png';

const stripHtml = (html) => {
  if (!html) return '';
  return html.replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim().slice(0, 120);
};
const articleDescription = article
  ? (stripHtml(article.body) || `fun sport nexus 実績：${article.title}`)
  : '実績詳細';
---
<BaseLayout
  title={article?.title ?? '実績'}
  description={articleDescription}
  ogImage={ogImageUrl}
>

  <article class="rs-article">
    <header class="rs-article__head">
      <nav class="rs-article__breadcrumb">
        <a href="/">トップ</a>
        <i class="fa-solid fa-angle-right"></i>
        <a href="/results/">開催実績</a>
      </nav>

      {fetchError ? (
        <div class="rs-article__error">
          <h1>実績を読み込めませんでした</h1>
          <p>しばらくしてから、再度お試しください。</p>
          <p style="font-size:0.78rem;color:var(--fsn-gray-500);margin-top:8px;">エラー：{fetchError}</p>
          <p style="margin-top:24px;">
            <a href="/results/" class="rs-article__back">
              <i class="fa-solid fa-arrow-left"></i> 実績一覧に戻る
            </a>
          </p>
        </div>
      ) : (
        <h1 class="rs-article__title">{article.title}</h1>
      )}
    </header>

    {!fetchError && article && eyecatchUrl && (
      <figure class="rs-article__eyecatch">
        <MicrocmsImage
          url={eyecatchUrl}
          mobileUrl={eyecatchMobileUrl}
          alt={article.title}
          width={1200}
          sizes="(max-width: 860px) 100vw, 860px"
          loading="eager"
          fetchpriority="high"
        />
      </figure>
    )}

    {!fetchError && article && (
      <dl class="rs-article__facts">
        {article.eventDate && (
          <div class="rs-fact">
            <dt><i class="fa-regular fa-calendar"></i> 開催日</dt>
            <dd>{formatDateRange(article.eventDate, article.eventEndDate)}</dd>
          </div>
        )}
        {(article.venue ?? article.Venue) && (
          <div class="rs-fact">
            <dt><i class="fa-solid fa-location-dot"></i> 会場</dt>
            <dd>{(article.venue ?? article.Venue)}</dd>
          </div>
        )}
        {(article.participants ?? article.particiant) && (
          <div class="rs-fact">
            <dt><i class="fa-solid fa-users"></i> 参加者数</dt>
            <dd>{(article.participants ?? article.particiant)}名</dd>
          </div>
        )}
        {article.partnerOrgs && (
          <div class="rs-fact">
            <dt><i class="fa-solid fa-handshake"></i> 連携団体</dt>
            <dd>{article.partnerOrgs}</dd>
          </div>
        )}
      </dl>
    )}

    {!fetchError && article && article.body && (
      <div class="rs-article__body" set:html={article.body}></div>
    )}

    {!fetchError && article && Array.isArray(article.gallery) && article.gallery.length > 0 && (
      <section class="rs-gallery">
        <h2 class="rs-gallery__heading">
          <i class="fa-regular fa-images"></i>
          写真ギャラリー
        </h2>
        <div class="rs-gallery__grid" data-gallery>
          {article.gallery.map((g, i) => {
            const url = g?.url ?? g?.image?.url;
            if (!url) return null;
            const caption = g?.caption || '';
            return (
              <button
                type="button"
                class="rs-gallery__item"
                data-full={`${url}?w=1600`}
                data-caption={caption}
                data-index={i}
                aria-label={caption || `写真 ${i + 1}`}
              >
                <img
                  src={`${url}?w=500&h=400&fit=crop`}
                  srcset={`${url}?w=300&h=240&fit=crop 300w, ${url}?w=500&h=400&fit=crop 500w, ${url}?w=800&h=640&fit=crop 800w`}
                  sizes="(max-width: 440px) 100vw, (max-width: 760px) 50vw, 33vw"
                  alt={caption}
                  loading="lazy"
                  decoding="async"
                />
                {caption && <span class="rs-gallery__caption">{caption}</span>}
              </button>
            );
          })}
        </div>
      </section>
    )}

    {!fetchError && article && (
      <div class="rs-article__footer">
        <a href="/results/" class="rs-article__back">
          <i class="fa-solid fa-arrow-left"></i>
          実績一覧に戻る
        </a>
      </div>
    )}
  </article>

  <!-- Lightbox -->
  <div class="rs-lightbox" data-lightbox hidden>
    <button class="rs-lightbox__close" type="button" data-lightbox-close aria-label="閉じる">
      <i class="fa-solid fa-xmark"></i>
    </button>
    <button class="rs-lightbox__prev" type="button" data-lightbox-prev aria-label="前の写真">
      <i class="fa-solid fa-chevron-left"></i>
    </button>
    <button class="rs-lightbox__next" type="button" data-lightbox-next aria-label="次の写真">
      <i class="fa-solid fa-chevron-right"></i>
    </button>
    <figure class="rs-lightbox__figure">
      <img class="rs-lightbox__img" data-lightbox-img alt="" />
      <figcaption class="rs-lightbox__caption" data-lightbox-caption></figcaption>
    </figure>
  </div>

</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const galleryEl = document.querySelector('[data-gallery]');
    const lightbox = document.querySelector('[data-lightbox]');
    if (!galleryEl || !lightbox) return;

    const items = Array.from(galleryEl.querySelectorAll('.rs-gallery__item'));
    const imgEl = lightbox.querySelector('[data-lightbox-img]');
    const captionEl = lightbox.querySelector('[data-lightbox-caption]');
    const closeBtn = lightbox.querySelector('[data-lightbox-close]');
    const prevBtn = lightbox.querySelector('[data-lightbox-prev]');
    const nextBtn = lightbox.querySelector('[data-lightbox-next]');

    let currentIndex = -1;

    const open = (i) => {
      if (i < 0 || i >= items.length) return;
      currentIndex = i;
      const btn = items[i];
      imgEl.src = btn.dataset.full || '';
      imgEl.alt = btn.dataset.caption || '';
      captionEl.textContent = btn.dataset.caption || '';
      captionEl.style.display = btn.dataset.caption ? '' : 'none';
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
      prevBtn.style.visibility = items.length > 1 ? '' : 'hidden';
      nextBtn.style.visibility = items.length > 1 ? '' : 'hidden';
    };
    const close = () => {
      lightbox.hidden = true;
      imgEl.src = '';
      document.body.style.overflow = '';
      currentIndex = -1;
    };
    const prev = () => open((currentIndex - 1 + items.length) % items.length);
    const next = () => open((currentIndex + 1) % items.length);

    items.forEach((btn, i) => btn.addEventListener('click', () => open(i)));
    closeBtn.addEventListener('click', close);
    prevBtn.addEventListener('click', prev);
    nextBtn.addEventListener('click', next);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) close();
    });
    document.addEventListener('keydown', (e) => {
      if (lightbox.hidden) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') prev();
      if (e.key === 'ArrowRight') next();
    });
  });
</script>

<style>
  .rs-article {
    max-width: 860px;
    margin: 0 auto;
    padding: 64px 24px 96px;
    min-height: 60vh;
  }
  .rs-article__breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    color: var(--fsn-gray-500);
    margin: 0 0 32px;
  }
  .rs-article__breadcrumb a { color: var(--fsn-navy); text-decoration: none; }
  .rs-article__breadcrumb a:hover { color: var(--fsn-orange); }
  .rs-article__breadcrumb i { color: var(--fsn-gray-300); font-size: 0.72rem; }

  .rs-article__title {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 800;
    color: var(--fsn-navy-deep);
    margin: 0 0 32px;
    line-height: 1.5;
    padding-bottom: 24px;
    border-bottom: 3px solid var(--fsn-orange);
  }

  .rs-article__eyecatch {
    margin: 0 0 32px;
    border-radius: var(--fsn-radius-md);
    overflow: hidden;
    box-shadow: var(--fsn-shadow-sm);
  }
  .rs-article__eyecatch img {
    width: 100%;
    height: auto;
    display: block;
  }

  .rs-article__facts {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px 24px;
    background: var(--fsn-gray-50);
    border-radius: var(--fsn-radius-md);
    padding: 24px 28px;
    margin: 0 0 40px;
  }
  @media (max-width: 600px) { .rs-article__facts { grid-template-columns: 1fr; } }
  .rs-fact { display: flex; flex-direction: column; gap: 6px; }
  .rs-fact dt {
    font-size: 0.78rem;
    font-weight: 800;
    color: var(--fsn-orange-dark);
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .rs-fact dt i { color: var(--fsn-orange); font-size: 0.88em; }
  .rs-fact dd {
    font-size: 1rem;
    font-weight: 700;
    color: var(--fsn-navy-deep);
    margin: 0;
    line-height: 1.5;
  }

  .rs-article__body {
    font-size: 1rem;
    line-height: 2;
    color: var(--fsn-gray-900);
  }
  .rs-article__body :global(h2) { display: none; }
  .rs-article__body :global(h3) {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--fsn-navy-deep);
    margin: 48px 0 16px;
    padding-left: 14px;
    border-left: 4px solid var(--fsn-orange);
  }
  .rs-article__body :global(h4) {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--fsn-navy);
    margin: 32px 0 12px;
  }
  .rs-article__body :global(p) { margin: 0 0 18px; }
  .rs-article__body :global(a) {
    color: var(--fsn-orange);
    text-decoration: underline;
  }
  .rs-article__body :global(img) {
    margin: 24px 0;
    border-radius: var(--fsn-radius-md);
    max-width: 100%;
    height: auto;
  }
  .rs-article__body :global(ul),
  .rs-article__body :global(ol) {
    margin: 16px 0;
    padding-left: 24px;
  }
  .rs-article__body :global(blockquote) {
    margin: 24px 0;
    padding: 16px 20px;
    background: var(--fsn-gray-50);
    border-left: 4px solid var(--fsn-orange);
    color: var(--fsn-gray-700);
    border-radius: 0 var(--fsn-radius-sm) var(--fsn-radius-sm) 0;
  }

  /* ============ Gallery ============ */
  .rs-gallery { margin: 48px 0 0; }
  .rs-gallery__heading {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--fsn-navy-deep);
    margin: 0 0 20px;
    padding-left: 14px;
    border-left: 4px solid var(--fsn-orange);
  }
  .rs-gallery__heading i { color: var(--fsn-orange); font-size: 0.95em; }
  .rs-gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 760px) { .rs-gallery__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 440px) { .rs-gallery__grid { grid-template-columns: 1fr; } }

  .rs-gallery__item {
    position: relative;
    border: 0;
    background: none;
    padding: 0;
    cursor: zoom-in;
    border-radius: var(--fsn-radius-sm);
    overflow: hidden;
    aspect-ratio: 5 / 4;
    box-shadow: var(--fsn-shadow-sm);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .rs-gallery__item:hover {
    transform: translateY(-3px);
    box-shadow: var(--fsn-shadow-md);
  }
  .rs-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .rs-gallery__item:hover img { transform: scale(1.04); }
  .rs-gallery__caption {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 8px 12px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0));
    color: #fff;
    font-size: 0.78rem;
    font-weight: 600;
    text-align: left;
    line-height: 1.4;
    pointer-events: none;
  }

  /* ============ Lightbox ============ */
  .rs-lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 60px;
  }
  .rs-lightbox[hidden] { display: none; }
  .rs-lightbox__figure {
    margin: 0;
    max-width: 100%;
    max-height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .rs-lightbox__img {
    max-width: 100%;
    max-height: calc(100vh - 140px);
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--fsn-radius-sm);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6);
  }
  .rs-lightbox__caption {
    color: #fff;
    font-size: 0.95rem;
    font-weight: 500;
    text-align: center;
    max-width: 800px;
    padding: 0 16px;
  }
  .rs-lightbox__close,
  .rs-lightbox__prev,
  .rs-lightbox__next {
    position: absolute;
    background: rgba(255, 255, 255, 0.12);
    border: 0;
    color: #fff;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, transform 0.15s;
  }
  .rs-lightbox__close:hover,
  .rs-lightbox__prev:hover,
  .rs-lightbox__next:hover {
    background: var(--fsn-orange);
    transform: scale(1.08);
  }
  .rs-lightbox__close { top: 24px; right: 24px; }
  .rs-lightbox__prev  { left: 24px; top: 50%; transform: translateY(-50%); }
  .rs-lightbox__next  { right: 24px; top: 50%; transform: translateY(-50%); }
  .rs-lightbox__prev:hover { transform: translateY(-50%) scale(1.08); }
  .rs-lightbox__next:hover { transform: translateY(-50%) scale(1.08); }

  @media (max-width: 600px) {
    .rs-lightbox { padding: 20px 12px; }
    .rs-lightbox__close,
    .rs-lightbox__prev,
    .rs-lightbox__next {
      width: 40px; height: 40px;
      font-size: 0.95rem;
    }
    .rs-lightbox__close { top: 12px; right: 12px; }
    .rs-lightbox__prev { left: 8px; }
    .rs-lightbox__next { right: 8px; }
  }

  .rs-article__footer {
    margin: 56px 0 0;
    padding-top: 32px;
    border-top: 1px solid var(--fsn-gray-200);
  }
  .rs-article__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: var(--fsn-navy-deep);
    color: var(--fsn-white);
    border-radius: var(--fsn-radius-pill);
    text-decoration: none;
    font-weight: 700;
    transition: background 0.2s;
  }
  .rs-article__back:hover {
    background: #050d2e;
    color: var(--fsn-white);
  }

  .rs-article__error {
    text-align: center;
    padding: 48px 24px;
    background: var(--fsn-gray-50);
    border-radius: var(--fsn-radius-md);
  }
</style>
