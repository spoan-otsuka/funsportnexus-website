---
/**
 * 共通ヘッダー
 * - 上部固定（fixed）
 * - ロゴ＋メインナビ＋お問い合わせCTA
 * - モバイル：ハンバーガーメニュー
 */

const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/news', label: 'お知らせ' },
  { href: '/events', label: '募集イベント' },
  { href: '/results', label: '実績' },
  { href: '/columns', label: 'コラム' },
  { href: '/business', label: '事業紹介' },
];
---

<header class="fsn-header">
  <div class="fsn-header__inner">
    <a href="/" class="fsn-header__logo">
      <span class="fsn-header__logo-text">
        <span class="fsn-header__logo-fun">fun</span>
        <span class="fsn-header__logo-sport">sport</span>
        <span class="fsn-header__logo-nexus">nexus</span>
      </span>
    </a>

    <input type="checkbox" id="fsn-nav-toggle" class="fsn-header__nav-toggle" />
    <label for="fsn-nav-toggle" class="fsn-header__hamburger" aria-label="メニューを開く">
      <span></span><span></span><span></span>
    </label>

    <nav class="fsn-header__nav">
      <ul class="fsn-header__nav-list">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class={`fsn-header__nav-link ${currentPath.startsWith(item.href) ? 'is-active' : ''}`}
            >{item.label}</a>
          </li>
        ))}
        <li class="fsn-header__cta">
          <a href="/contact" class="fsn-header__cta-btn">お問い合わせ</a>
        </li>
      </ul>
    </nav>
    <label for="fsn-nav-toggle" class="fsn-header__overlay"></label>
  </div>
</header>

<style>
  .fsn-header {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--fsn-gray-200);
    z-index: 100;
    height: 72px;
  }
  .fsn-header__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .fsn-header__logo {
    text-decoration: none;
    line-height: 1;
  }
  .fsn-header__logo-text {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: 0.01em;
  }
  .fsn-header__logo-fun { color: var(--fsn-orange); }
  .fsn-header__logo-sport { color: var(--fsn-navy); }
  .fsn-header__logo-nexus { color: var(--fsn-navy); }

  .fsn-header__nav-toggle { display: none; }
  .fsn-header__hamburger {
    display: none;
    width: 32px;
    height: 24px;
    flex-direction: column;
    justify-content: space-between;
    cursor: pointer;
    position: relative;
    z-index: 101;
  }
  .fsn-header__hamburger span {
    display: block;
    height: 3px;
    background: var(--fsn-navy);
    border-radius: 2px;
    transition: transform .2s, opacity .2s;
  }

  .fsn-header__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .fsn-header__nav-link {
    color: var(--fsn-navy);
    font-size: 0.92rem;
    font-weight: 600;
    padding: 8px 4px;
    position: relative;
    text-decoration: none;
    transition: color .15s;
  }
  .fsn-header__nav-link:hover { color: var(--fsn-orange); }
  .fsn-header__nav-link.is-active::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 3px;
    background: var(--fsn-orange);
    border-radius: 2px;
  }

  .fsn-header__cta-btn {
    background: var(--fsn-orange);
    color: var(--fsn-white);
    padding: 12px 24px;
    border-radius: var(--fsn-radius-pill);
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: none;
    transition: background .2s, transform .2s;
    box-shadow: 0 4px 12px rgba(249, 115, 22, 0.25);
  }
  .fsn-header__cta-btn:hover {
    background: var(--fsn-orange-dark);
    transform: translateY(-1px);
    color: var(--fsn-white);
  }

  .fsn-header__overlay { display: none; }

  @media (max-width: 900px) {
    .fsn-header__hamburger { display: flex; }
    .fsn-header__nav {
      position: fixed;
      top: 0;
      right: -300px;
      width: 280px;
      height: 100vh;
      background: var(--fsn-white);
      box-shadow: -4px 0 24px rgba(0, 0, 0, 0.1);
      padding: 96px 24px 24px;
      transition: right .25s ease;
      z-index: 100;
    }
    .fsn-header__nav-list {
      flex-direction: column;
      align-items: stretch;
      gap: 4px;
    }
    .fsn-header__nav-link {
      display: block;
      padding: 16px 12px;
      border-bottom: 1px solid var(--fsn-gray-200);
    }
    .fsn-header__cta { margin-top: 16px; }
    .fsn-header__cta-btn {
      display: block;
      text-align: center;
    }
    .fsn-header__nav-toggle:checked ~ .fsn-header__nav { right: 0; }
    .fsn-header__nav-toggle:checked ~ .fsn-header__overlay {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.4);
      z-index: 99;
    }
  }
</style>
